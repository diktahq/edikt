erDiagram
    User {
        uuid id PK
        string email UK "NOT NULL"
        string name "NOT NULL"
        timestamp created_at "NOT NULL"
    }
    Post {
        uuid id PK
        uuid user_id FK "NOT NULL"
        string title "NOT NULL"
        text body
        timestamp created_at "NOT NULL"
    }
    Comment {
        uuid id PK
        uuid post_id FK "NOT NULL"
        uuid user_id FK "NOT NULL"
        text body "NOT NULL"
        timestamp created_at "NOT NULL"
    }
    User ||--o{ Post : "authors"
    User ||--o{ Comment : "writes"
    Post ||--o{ Comment : "has"
    %% Index: User.email — unique lookup by email
    %% Index: Post.user_id — posts by user
    %% Index: Comment.post_id — comments on post
