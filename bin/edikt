#!/bin/sh
# edikt-shell — migrate-only shell helper (ADR-022 strangler-fig, v0.5.0+).
#
# This file now handles ONLY the `migrate` subcommand.
# All other subcommands have moved to the Go `edikt` binary.
#
# If called directly (not via EDIKT_SHELL_CALLER=1) with any subcommand
# other than `migrate`, it prints an error and exits 1.
#
# When called by the Go binary, EDIKT_SHELL_CALLER=1 is set.
#
# Strict POSIX: no bashisms, no [[ ]], no arrays, no `source`.

set -u

umask 022

# ─── Guard: redirect non-migrate callers ─────────────────────────────────────
# If we were NOT invoked via the Go binary and the first arg is not `migrate`,
# print an error directing users to the Go binary.
if [ -z "${EDIKT_SHELL_CALLER:-}" ]; then
    sub="${1:-help}"
    case "$sub" in
        migrate) ;;
        *)
            echo "error: this command has moved to the Go binary — run \`edikt $sub\`" >&2
            exit 1
            ;;
    esac
fi

# ─── Constants ───────────────────────────────────────────────────────────────
LAUNCHER_VERSION="0.5.0"
MIN_PAYLOAD_VERSION="0.5.0"

# Exit codes (per SPEC-004 §2)
EX_OK=0
EX_CHECKSUM=2
EX_ALREADY=3
EX_LOCKED=4

# Event log rotation threshold (10 MiB per config-spec §4.4)
EVENTS_MAX_BYTES=10485760

# ─── EDIKT_ROOT resolution ────────────────────────────────────────────────────
resolve_edikt_root() {
    if [ -n "${EDIKT_ROOT:-}" ]; then
        echo "$EDIKT_ROOT"
        return 0
    fi
    dir="$PWD"
    _home="${HOME:-/nonexistent}"
    while [ -n "$dir" ] && [ "$dir" != "/" ] && [ "$dir" != "$_home" ]; do
        if [ -x "$dir/.edikt/bin/edikt" ] && [ -O "$dir/.edikt/bin/edikt" ]; then
            echo "$dir/.edikt"
            return 0
        fi
        dir=$(dirname "$dir")
    done
    if [ -n "${EDIKT_HOME:-}" ]; then
        echo "$EDIKT_HOME"
    else
        echo "${HOME:-/}/.edikt"
    fi
}

resolve_claude_root() {
    if [ -n "${CLAUDE_HOME:-}" ]; then
        echo "$CLAUDE_HOME"
    else
        echo "${HOME:-/}/.claude"
    fi
}

if [ -z "${EDIKT_ROOT:-}" ]; then
    EDIKT_ROOT=$(resolve_edikt_root)
fi
CLAUDE_ROOT=$(resolve_claude_root)

# ─── SHA256 dispatch ──────────────────────────────────────────────────────────
sha256_file() {
    f="$1"
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$f" | awk '{print $1}'
    elif command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$f" | awk '{print $1}'
    else
        echo "error: need sha256sum or shasum" >&2
        return 1
    fi
}

# ─── Sidecar checksum verification ───────────────────────────────────────────
verify_against_sidecar() {
    _observed="$1"
    _ref_file="$2"
    _ref_label="$3"
    _expected=$(awk '{print $1; exit}' "$_ref_file" 2>/dev/null | tr -d '[:space:]')
    if [ -z "$_expected" ]; then
        log_err "checksum reference $_ref_label is empty"
        return 1
    fi
    if [ "$_observed" != "$_expected" ]; then
        log_err "checksum mismatch: reference $_ref_label expected $_expected, got $_observed"
        return 1
    fi
    return 0
}

# ─── ISO-8601 UTC timestamp ───────────────────────────────────────────────────
iso_now() {
    date -u +%Y-%m-%dT%H:%M:%SZ
}

ts_now() {
    date -u +%Y%m%dT%H%M%SZ
}

# ─── Logging ──────────────────────────────────────────────────────────────────
log_info() { echo "$@" >&2; }
log_warn() { echo "warn: $*" >&2; }
log_err()  { echo "error: $*" >&2; }

# ─── flock serialization ──────────────────────────────────────────────────────
LOCK_HELD=""
LOCK_DIR=""
LOCK_FD=""

acquire_lock() {
    mkdir -p "$EDIKT_ROOT" || return 1
    lockfile="$EDIKT_ROOT/.lock"

    if command -v flock >/dev/null 2>&1; then
        if (
            exec 9>"$lockfile" 2>/dev/null
            flock -n 9 2>/dev/null
        ); then
            exec 9>"$lockfile"
            if flock -n 9 2>/dev/null; then
                LOCK_HELD="flock"
                LOCK_FD=9
                printf '%s %s\n' "$$" "$(iso_now)" >&9
                return 0
            fi
            log_err "another edikt process is running (lock: $lockfile). Retry or remove stale lock."
            return 4
        fi
    fi

    LOCK_DIR="$EDIKT_ROOT/.lock.d"
    if ! mkdir "$LOCK_DIR" 2>/dev/null; then
        stale=0
        if [ -f "$LOCK_DIR/owner" ]; then
            owner_pid=$(awk '{print $1; exit}' "$LOCK_DIR/owner" 2>/dev/null)
            if [ -n "$owner_pid" ] && ! kill -0 "$owner_pid" 2>/dev/null; then
                stale=1
            fi
        fi
        if [ "$stale" -eq 1 ]; then
            log_warn "reclaiming stale lock dir $LOCK_DIR"
            rm -rf "$LOCK_DIR" 2>/dev/null || true
            if ! mkdir "$LOCK_DIR" 2>/dev/null; then
                log_err "another edikt process is running (lock dir: $LOCK_DIR). Retry or remove stale lock."
                return 4
            fi
        else
            log_err "another edikt process is running (lock dir: $LOCK_DIR). Retry or remove stale lock."
            return 4
        fi
    fi
    printf '%s %s\n' "$$" "$(iso_now)" >"$LOCK_DIR/owner" 2>/dev/null || true
    LOCK_HELD="mkdir"
    return 0
}

release_lock() {
    if [ "$LOCK_HELD" = "mkdir" ] && [ -n "$LOCK_DIR" ]; then
        rm -rf "$LOCK_DIR" 2>/dev/null || true
    elif [ "$LOCK_HELD" = "flock" ] && [ -n "$LOCK_FD" ]; then
        exec 9>&- 2>/dev/null || true
    fi
    LOCK_HELD=""
}

# ─── Global exit trap ─────────────────────────────────────────────────────────
edikt_exit_trap() {
    _rc=$?
    _signum="${1:-}"
    case "${MIGRATE_STATE:-}" in
        ""|idle|done) ;;
        *)
            case "$_signum" in
                INT)  _rc=130 ;;
                TERM) _rc=143 ;;
            esac
            migrate_trap_handler "$_rc" 2>/dev/null || true
            ;;
    esac
    release_lock
    return "$_rc"
}
trap 'edikt_exit_trap' EXIT
trap 'edikt_exit_trap INT'  INT
trap 'edikt_exit_trap TERM' TERM

# ─── Atomic write helper ──────────────────────────────────────────────────────
atomic_write() {
    dest="$1"
    tmp="$dest.tmp.$$"
    cat >"$tmp" || { rm -f "$tmp"; return 1; }
    mv -f "$tmp" "$dest"
}

# ─── Event emission ───────────────────────────────────────────────────────────
emit_event() {
    typ="$1"
    extra="${2:-}"
    mkdir -p "$EDIKT_ROOT" 2>/dev/null || return 0
    line='{"event":"'"$typ"'","timestamp":"'"$(iso_now)"'"'
    if [ -n "$extra" ]; then
        line="$line,$extra"
    fi
    line="$line}"
    evlog="$EDIKT_ROOT/events.jsonl"
    if [ -f "$evlog" ]; then
        cur_sz=0
        if stat -f '%z' "$evlog" >/dev/null 2>&1; then
            cur_sz=$(stat -f '%z' "$evlog" 2>/dev/null || echo 0)
        elif stat -c '%s' "$evlog" >/dev/null 2>&1; then
            cur_sz=$(stat -c '%s' "$evlog" 2>/dev/null || echo 0)
        fi
        add_sz=$(( ${#line} + 1 ))
        if [ $(( cur_sz + add_sz )) -gt "$EVENTS_MAX_BYTES" ]; then
            mv -f "$evlog" "$evlog.1" 2>/dev/null || true
        fi
    fi
    printf '%s\n' "$line" >>"$evlog"
}

# ─── Version comparison ───────────────────────────────────────────────────────
version_ge() {
    a="$1"
    b="$2"
    a_norm=$(echo "$a" | sed 's/^v//')
    b_norm=$(echo "$b" | sed 's/^v//')
    awk -v a="$a_norm" -v b="$b_norm" 'BEGIN {
        na = split(a, A, /\./)
        nb = split(b, B, /\./)
        n = (na > nb) ? na : nb
        for (i = 1; i <= n; i++) {
            ai = (i in A) ? A[i] + 0 : 0
            bi = (i in B) ? B[i] + 0 : 0
            if (ai > bi) exit 0
            if (ai < bi) exit 1
        }
        exit 0
    }'
}

normalize_tag() {
    echo "$1" | sed 's/^v//'
}

# ─── lock.yaml read helpers ───────────────────────────────────────────────────
lock_get() {
    key="$1"
    f="$EDIKT_ROOT/lock.yaml"
    [ -f "$f" ] || return 0
    awk -v k="$key" '
        $0 ~ "^"k":" {
            sub("^"k":[ \t]*", "")
            gsub(/^["\047]|["\047]$/, "")
            print
            exit
        }
    ' "$f"
}

# ─── lock.yaml write (atomic) ─────────────────────────────────────────────────
lock_write() {
    new_active="$1"
    new_installed_via="$2"
    now=$(iso_now)
    f="$EDIKT_ROOT/lock.yaml"

    prev_active=$(lock_get active)
    tmp="$f.tmp.$$"
    {
        printf 'active: "%s"\n' "$new_active"
        if [ -n "$prev_active" ] && [ "$prev_active" != "$new_active" ]; then
            printf 'previous: "%s"\n' "$prev_active"
        elif [ -n "$(lock_get previous)" ]; then
            printf 'previous: "%s"\n' "$(lock_get previous)"
        fi
        printf 'installed_at: "%s"\n' "$now"
        printf 'installed_via: "%s"\n' "$new_installed_via"
        printf 'history:\n'
        if [ -f "$f" ]; then
            awk '
                /^history:/ { in_hist = 1; next }
                in_hist && /^[a-zA-Z]/ { in_hist = 0 }
                in_hist { print }
            ' "$f" | head -98
        fi
        printf '  - version: "%s"\n' "$new_active"
        printf '    installed_at: "%s"\n' "$now"
        printf '    activated_at: "%s"\n' "$now"
        printf '    installed_via: "%s"\n' "$new_installed_via"
    } >"$tmp"
    mv -f "$tmp" "$f"
}

# ─── Symlink chain helpers ────────────────────────────────────────────────────
atomic_symlink() {
    target="$1"
    link="$2"
    new="$link.new.$$"
    rm -f "$new" 2>/dev/null || true
    ln -s "$target" "$new" || return 1
    if mv -hf "$new" "$link" 2>/dev/null; then
        return 0
    fi
    if mv -Tf "$new" "$link" 2>/dev/null; then
        return 0
    fi
    rm -f "$new" 2>/dev/null || true
    ln -sfn "$target" "$link"
}

resolve_commands_target() {
    if [ ! -e "$EDIKT_ROOT/current" ]; then
        log_err "resolve_commands_target: $EDIKT_ROOT/current does not exist"
        return 1
    fi
    if [ -L "$EDIKT_ROOT/current" ] && [ ! -d "$EDIKT_ROOT/current/" ]; then
        log_err "resolve_commands_target: $EDIKT_ROOT/current is a broken symlink"
        return 1
    fi
    if [ -d "$EDIKT_ROOT/current/commands/edikt" ]; then
        printf '%s' "$EDIKT_ROOT/current/commands/edikt"
        return 0
    fi
    if [ -d "$EDIKT_ROOT/current/commands" ]; then
        printf '%s' "$EDIKT_ROOT/current/commands"
        return 0
    fi
    log_err "resolve_commands_target: $EDIKT_ROOT/current has neither commands/ nor commands/edikt/ — payload is malformed"
    return 1
}

resolve_hooks_target() {
    if [ ! -e "$EDIKT_ROOT/current" ]; then
        log_err "resolve_hooks_target: $EDIKT_ROOT/current does not exist"
        return 1
    fi
    if [ -L "$EDIKT_ROOT/current" ] && [ ! -d "$EDIKT_ROOT/current/" ]; then
        log_err "resolve_hooks_target: $EDIKT_ROOT/current is a broken symlink"
        return 1
    fi
    if [ -d "$EDIKT_ROOT/current/hooks" ]; then
        printf '%s' "current/hooks"
        return 0
    fi
    if [ -d "$EDIKT_ROOT/current/templates/hooks" ]; then
        printf '%s' "current/templates/hooks"
        return 0
    fi
    log_err "resolve_hooks_target: $EDIKT_ROOT/current has neither hooks/ nor templates/hooks/ — payload is malformed"
    return 1
}

ensure_external_symlinks() {
    if _hooks_target=$(resolve_hooks_target); then
        atomic_symlink "$_hooks_target" "$EDIKT_ROOT/hooks"
    else
        return 1
    fi
    atomic_symlink current/templates "$EDIKT_ROOT/templates"
    mkdir -p "$CLAUDE_ROOT/commands"
    if _cmds_target=$(resolve_commands_target); then
        atomic_symlink "$_cmds_target" "$CLAUDE_ROOT/commands/edikt"
    else
        return 1
    fi
}

flip_current() {
    target="$1"
    ts=$(ts_now)
    backup_dir="$EDIKT_ROOT/backups/$ts"
    mkdir -p "$backup_dir"

    if [ -L "$EDIKT_ROOT/current" ]; then
        prior=$(readlink "$EDIKT_ROOT/current")
        printf '%s\n' "$prior" >"$backup_dir/prior_target"
    fi

    atomic_symlink "$target" "$EDIKT_ROOT/current"
    ensure_external_symlinks

    echo "$ts"
}

# ─── manifest.yaml writer ─────────────────────────────────────────────────────
write_manifest() {
    version_dir="$1"
    version="$2"
    source_type="$3"
    source_url="$4"
    tarball_sha="$5"

    manifest="$version_dir/manifest.yaml"
    tmp="$manifest.tmp.$$"
    {
        printf 'version: "%s"\n' "$version"
        printf 'installed_at: "%s"\n' "$(iso_now)"
        printf 'source:\n'
        printf '  type: "%s"\n' "$source_type"
        if [ -n "$source_url" ]; then
            printf '  url: "%s"\n' "$source_url"
        fi
        if [ -n "$tarball_sha" ]; then
            printf '  sha256: "%s"\n' "$tarball_sha"
        fi
        printf 'files:\n'
        ( cd "$version_dir" && find . -type f \
            ! -name 'manifest.yaml' \
            ! -name 'manifest.yaml.tmp.*' \
            | sed 's|^\./||' | LC_ALL=C sort ) | while IFS= read -r relpath; do
            sha=$(sha256_file "$version_dir/$relpath") || continue
            mode=$(stat_mode "$version_dir/$relpath")
            printf '  - path: "%s"\n' "$relpath"
            printf '    sha256: "%s"\n' "$sha"
            printf '    mode: "%s"\n' "$mode"
        done
    } >"$tmp"
    mv -f "$tmp" "$manifest"
}

stat_mode() {
    f="$1"
    if stat -f '%Lp' "$f" >/dev/null 2>&1; then
        printf '0%s' "$(stat -f '%Lp' "$f")"
    elif stat -c '%a' "$f" >/dev/null 2>&1; then
        printf '0%s' "$(stat -c '%a' "$f")"
    else
        printf '0644'
    fi
}

manifest_verify() {
    version_dir="$1"
    manifest="$version_dir/manifest.yaml"
    [ -f "$manifest" ] || { log_err "no manifest at $manifest"; return 1; }

    pairs="$version_dir/.manifest-pairs.$$"
    awk '
        /^  - path:/    { if (match($0, /"[^"]*"/)) path = substr($0, RSTART+1, RLENGTH-2); next }
        /^    sha256:/  { if (match($0, /"[^"]*"/)) print path, substr($0, RSTART+1, RLENGTH-2) }
    ' "$manifest" >"$pairs"

    bad=0
    while read -r p s; do
        [ -n "$p" ] && [ -n "$s" ] || continue
        if [ ! -f "$version_dir/$p" ]; then
            echo "missing: $p" >&2
            bad=1
            continue
        fi
        actual=$(sha256_file "$version_dir/$p")
        if [ "$actual" != "$s" ]; then
            echo "tampered: $p (expected $s, got $actual)" >&2
            bad=1
        fi
    done <"$pairs"
    rm -f "$pairs"
    return $bad
}

check_payload_min_version() {
    payload_dir="$1"
    vfile="$payload_dir/VERSION"
    if [ ! -f "$vfile" ]; then
        log_err "payload at $payload_dir is missing VERSION file"
        return 1
    fi
    payload_v=$(head -1 "$vfile" | tr -d '[:space:]')
    if ! version_ge "$payload_v" "$MIN_PAYLOAD_VERSION"; then
        log_err "payload version $payload_v is older than launcher MIN_PAYLOAD_VERSION ($MIN_PAYLOAD_VERSION)."
        return 1
    fi
    return 0
}

# ─── Legacy-layout detection ──────────────────────────────────────────────────
needs_migration() {
    [ -d "$EDIKT_ROOT/hooks" ] && [ ! -L "$EDIKT_ROOT/hooks" ] && [ -f "$EDIKT_ROOT/VERSION" ]
}

migration_in_progress() {
    for d in "$EDIKT_ROOT"/.migrate-staging-* "$EDIKT_ROOT"/.pre-migration-*; do
        [ -e "$d" ] && return 0
    done
    return 1
}

# ─── M2: CLAUDE.md HTML sentinels → markdown link-ref form (ADR-006) ─────────
MIGRATE_RAN_M2=0
MIGRATE_RAN_M3=0
MIGRATE_RAN_M4=0
MIGRATE_RAN_M5=0
MIGRATE_M3_PRESERVED=""

_ensure_secondary_backup_dir() {
    if [ -n "${MIGRATE_BACKUP_DIR:-}" ] && [ -d "$MIGRATE_BACKUP_DIR" ]; then
        return 0
    fi
    _ts="${MIGRATE_TS:-$(ts_now)}"
    MIGRATE_TS="$_ts"
    MIGRATE_BACKUP_DIR="$EDIKT_ROOT/backups/migration-$_ts-$$"
    mkdir -p "$MIGRATE_BACKUP_DIR" 2>/dev/null || return 1
    return 0
}

migrate_m2_claudemd_sentinels() {
    _dry="$1"
    _f="$EDIKT_ROOT/CLAUDE.md"
    [ -f "$_f" ] || return 0
    if [ "$_dry" -eq 1 ]; then
        if [ -L "$_f" ]; then
            log_err "M2: CLAUDE.md is a symlink — migration refuses to follow it."
            return 1
        fi
        if ! grep -q '<!-- edikt:start -->' "$_f" 2>/dev/null; then return 0; fi
        if ! grep -q '<!-- edikt:end -->' "$_f" 2>/dev/null; then return 0; fi
        log_info "M2 (CLAUDE.md sentinels): would rewrite HTML sentinels in $_f to markdown link-ref form"
        return 0
    fi
    _ensure_secondary_backup_dir || {
        log_err "M2: could not create backup dir"
        return 1
    }
    python3 - "$_f" "$MIGRATE_BACKUP_DIR/CLAUDE.md.pre-m2" <<'PY'
import os
import sys

src, backup = sys.argv[1], sys.argv[2]

try:
    fd = os.open(src, os.O_RDONLY | os.O_NOFOLLOW)
except FileNotFoundError:
    sys.exit(0)
except OSError as exc:
    if getattr(exc, 'errno', None) in (40,):
        sys.stderr.write(f"M2: {src} is a symlink — refusing to follow\n")
        sys.exit(2)
    sys.stderr.write(f"M2: open failed: {exc}\n")
    sys.exit(1)

try:
    with os.fdopen(fd, 'rb') as f:
        content = f.read()
except OSError as exc:
    sys.stderr.write(f"M2: read failed: {exc}\n")
    sys.exit(1)

if b'<!-- edikt:start -->' not in content or b'<!-- edikt:end -->' not in content:
    sys.exit(0)

new_content = content.replace(
    b'<!-- edikt:start -->', b'[edikt:start]: #'
).replace(
    b'<!-- edikt:end -->', b'[edikt:end]: #'
)

try:
    with open(backup, 'wb') as f:
        f.write(content)
except OSError as exc:
    sys.stderr.write(f"M2: backup write failed: {exc}\n")
    sys.exit(1)

dst_dir = os.path.dirname(src) or '.'
tmp_path = os.path.join(dst_dir, f".{os.path.basename(src)}.tmp.{os.getpid()}")
try:
    tfd = os.open(tmp_path, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o644)
    with os.fdopen(tfd, 'wb') as f:
        f.write(new_content)
        f.flush()
        os.fsync(f.fileno())
    try:
        check_fd = os.open(src, os.O_RDONLY | os.O_NOFOLLOW)
        os.close(check_fd)
    except FileNotFoundError:
        pass
    except OSError as exc:
        if getattr(exc, 'errno', None) in (40,):
            os.remove(tmp_path)
            sys.stderr.write(f"M2: {src} became a symlink during migration — aborting\n")
            sys.exit(2)
        raise
    os.replace(tmp_path, src)
except OSError as exc:
    try:
        os.remove(tmp_path)
    except OSError:
        pass
    sys.stderr.write(f"M2: atomic write failed: {exc}\n")
    sys.exit(1)
PY
    rc=$?
    if [ "$rc" -ne 0 ]; then
        if [ "$rc" -eq 2 ]; then
            log_err "M2: CLAUDE.md symlink detected during migration — aborting safely"
        else
            log_err "M2: migration failed — see error above"
        fi
        return 1
    fi
    MIGRATE_RAN_M2=1
    log_info "M2: rewrote sentinels in $_f (backup at $MIGRATE_BACKUP_DIR/CLAUDE.md.pre-m2)"
    emit_event migration_step_completed \
        '"step":"M2","file":"'"$_f"'"'
    return 0
}

# ─── M3: flat command names → namespaced ─────────────────────────────────────
migrate_m3_flat_commands() {
    _dry="$1"
    _flat_dir="$CLAUDE_ROOT/commands/edikt"
    _payload_dir="$EDIKT_ROOT/current/commands/edikt"
    [ -d "$_flat_dir" ] || return 0
    if ! [ -d "$_payload_dir" ]; then
        if [ -L "$EDIKT_ROOT/current" ] && ! [ -e "$EDIKT_ROOT/current" ]; then
            log_err "M3: \$EDIKT_ROOT/current is a broken symlink — cannot determine namespaced replacements."
            return 1
        fi
        return 0
    fi
    _custom_dir="$EDIKT_ROOT/custom"

    _match_file=$(mktemp -t edikt-m3-matches-XXXXXX)
    # shellcheck disable=SC2064
    trap "rm -f '$_match_file'" RETURN
    for _flat in "$_flat_dir"/*.md; do
        [ -f "$_flat" ] || continue
        [ -L "$_flat" ] && continue
        _base=$(basename "$_flat")
        _replacement=$(find "$_payload_dir" -mindepth 2 -type f -name "$_base" 2>/dev/null | head -1)
        [ -n "$_replacement" ] || continue
        printf '%s\t%s\n' "$_flat" "$_replacement" >>"$_match_file"
    done
    if ! [ -s "$_match_file" ]; then
        rm -f "$_match_file"
        return 0
    fi

    if [ "$_dry" -eq 1 ]; then
        while IFS="$(printf '\t')" read -r _flat _repl; do
            log_info "M3 (flat commands): would compare $_flat vs $_repl"
        done <"$_match_file"
        rm -f "$_match_file"
        return 0
    fi

    while IFS="$(printf '\t')" read -r _flat _repl; do
        _flat_sha=$(sha256_file "$_flat" 2>/dev/null) || _flat_sha=""
        _repl_sha=$(sha256_file "$_repl" 2>/dev/null) || _repl_sha=""
        if [ -n "$_flat_sha" ] && [ "$_flat_sha" = "$_repl_sha" ]; then
            _safe_remove_or_quarantine "$_flat" "M3" || {
                log_err "M3: failed to remove $_flat"
                return 1
            }
            log_info "M3: removed unmodified flat command: $_flat"
            emit_event migration_step_completed \
                '"step":"M3","action":"removed","file":"'"$_flat"'"'
        else
            mkdir -p "$_custom_dir" || {
                log_err "M3: failed to create $_custom_dir"
                return 1
            }
            _dest="$_custom_dir/$(basename "$_flat")"
            mv "$_flat" "$_dest" || {
                log_err "M3: failed to mv $_flat → $_dest"
                return 1
            }
            log_warn "Preserved user-modified command: $(basename "$_flat") → $_custom_dir/"
            MIGRATE_M3_PRESERVED="$MIGRATE_M3_PRESERVED $_dest"
            emit_event migration_step_completed \
                '"step":"M3","action":"preserved","file":"'"$_dest"'"'
        fi
        MIGRATE_RAN_M3=1
    done <"$_match_file"
    rm -f "$_match_file"
    return 0
}

# ─── M5: config.yaml schema additions ────────────────────────────────────────
migrate_m5_config_additions() {
    _dry="$1"
    _f="$EDIKT_ROOT/config.yaml"
    [ -f "$_f" ] || return 0

    _missing=""
    grep -q '^paths:' "$_f" 2>/dev/null || _missing="$_missing paths"
    grep -q '^stack:' "$_f" 2>/dev/null || _missing="$_missing stack"
    grep -q '^gates:' "$_f" 2>/dev/null || _missing="$_missing gates"

    [ -n "$_missing" ] || return 0

    if [ "$_dry" -eq 1 ]; then
        log_info "M5 (config.yaml): would append missing keys to $_f:$_missing"
        return 0
    fi
    _ensure_secondary_backup_dir || {
        log_err "M5: could not create backup dir"
        return 1
    }
    cp "$_f" "$MIGRATE_BACKUP_DIR/config.yaml.pre-m5" || {
        log_err "M5: failed to back up $_f"
        return 1
    }

    _tmp="$_f.tmp.$$"
    cp "$_f" "$_tmp" || {
        log_err "M5: failed to seed temp file"
        return 1
    }
    if [ -s "$_tmp" ]; then
        printf '\n' >>"$_tmp"
    fi

    for _key in $_missing; do
        case "$_key" in
            paths)
                cat >>"$_tmp" <<'EOF'

# Added by edikt v0.5.0 migration
paths:
  decisions: docs/architecture/decisions
  invariants: docs/architecture/invariants
  plans: docs/plans
  specs: docs/product/specs
  prds: docs/product/prds
  guidelines: docs/guidelines
  reports: docs/reports
  project-context: docs/project-context.md
EOF
                ;;
            stack)
                cat >>"$_tmp" <<'EOF'

# Added by edikt v0.5.0 migration
stack: []
EOF
                ;;
            gates)
                cat >>"$_tmp" <<'EOF'

# Added by edikt v0.5.0 migration
gates:
  quality-gates: true
EOF
                ;;
        esac
    done

    mv -f "$_tmp" "$_f" || {
        rm -f "$_tmp"
        log_err "M5: atomic mv failed"
        return 1
    }
    MIGRATE_RAN_M5=1
    log_info "M5: appended missing keys to $_f:$_missing"
    emit_event migration_step_completed \
        '"step":"M5","keys":"'"$(echo "$_missing" | sed 's/^ //;s/ /,/g')"'"'
    return 0
}

# ─── M4: compile schema v1 → v2 ──────────────────────────────────────────────
migrate_m4_compile_schema_v1_to_v2() {
    _dry="$1"
    _gov="$CLAUDE_ROOT/rules/governance.md"
    [ -f "$_gov" ] || return 0
    if grep -q 'compile_schema_version: 2' "$_gov" 2>/dev/null; then
        return 0
    fi
    if [ -f "$EDIKT_ROOT/.m4-pending" ]; then
        return 0
    fi
    if [ "$_dry" -eq 1 ]; then
        log_info "M4 (compile schema): would invoke 'claude -p /edikt:gov:compile' to migrate governance.md to schema v2"
        return 0
    fi
    _claude_bin=""
    if command -v claude >/dev/null 2>&1; then
        _claude_bin="claude"
    fi
    if [ -n "$_claude_bin" ]; then
        log_info "M4 (compile schema): invoking 'claude -p /edikt:gov:compile' to upgrade governance.md to schema v2"
        if "$_claude_bin" -p "/edikt:gov:compile" >/dev/null 2>&1 \
            && grep -q 'compile_schema_version: 2' "$_gov" 2>/dev/null; then
            MIGRATE_RAN_M4=1
            emit_event migration_step_completed \
                '"step":"M4","action":"compiled","result":"schema_v2"'
            log_info "M4 (compile schema): governance.md upgraded to schema v2"
            return 0
        else
            log_warn "M4: claude -p /edikt:gov:compile failed or produced no v2 sentinel — falling back to .m4-pending marker"
        fi
    else
        log_warn "M4: claude CLI not found — falling back to .m4-pending marker"
    fi
    : >"$EDIKT_ROOT/.m4-pending" || {
        log_warn "M4: could not write $EDIKT_ROOT/.m4-pending (non-fatal)"
        return 0
    }
    MIGRATE_RAN_M4=1
    emit_event migration_step_completed \
        '"step":"M4","action":"pending","marker":"'"$EDIKT_ROOT/.m4-pending"'"'
    log_warn "M4: governance.md schema migration pending — run /edikt:gov:compile to complete"
    return 0
}

# ─── M6: provenance backfill — no-op in migration chain ──────────────────────
migrate_m6_provenance_backfill() {
    : "${1:-}"
    return 0
}

_run_secondary_migrations() {
    _dry="$1"
    migrate_m2_claudemd_sentinels "$_dry" || return $?
    migrate_m3_flat_commands "$_dry" || return $?
    migrate_m5_config_additions "$_dry" || return $?
    migrate_m4_compile_schema_v1_to_v2 "$_dry" || return $?
    migrate_m6_provenance_backfill "$_dry" || return $?
    return 0
}

_print_secondary_summary() {
    _ran_any=0
    if [ "$MIGRATE_RAN_M2" -eq 1 ]; then echo "  M2: CLAUDE.md sentinels rewritten"; _ran_any=1; fi
    if [ "$MIGRATE_RAN_M3" -eq 1 ]; then
        echo "  M3: flat command names normalized"
        _ran_any=1
        if [ -n "$MIGRATE_M3_PRESERVED" ]; then
            echo "    user-modified files preserved:$MIGRATE_M3_PRESERVED"
        fi
    fi
    if [ "$MIGRATE_RAN_M5" -eq 1 ]; then echo "  M5: config.yaml keys added"; _ran_any=1; fi
    if [ "$MIGRATE_RAN_M4" -eq 1 ]; then echo "  M4: compile schema marked pending (deferred to Phase 7b)"; _ran_any=1; fi
    [ "$_ran_any" -eq 0 ] && echo "  (M2-M6: no signals detected)"
    if [ "$MIGRATE_RAN_M2" -eq 1 ] || [ "$MIGRATE_RAN_M5" -eq 1 ]; then
        echo ""
        echo "Migration backups retained at: $MIGRATE_BACKUP_DIR/"
        if [ "$MIGRATE_RAN_M2" -eq 1 ]; then
            echo "  CLAUDE.md.pre-m2    — M2 original"
        fi
        if [ "$MIGRATE_RAN_M5" -eq 1 ]; then
            echo "  config.yaml.pre-m5  — M5 original"
        fi
        echo ""
        echo "To restore manually:"
        if [ "$MIGRATE_RAN_M2" -eq 1 ]; then
            _m2_backup="$MIGRATE_BACKUP_DIR/CLAUDE.md.pre-m2"
            echo "  cp $_m2_backup <path-to-CLAUDE.md>"
        fi
        if [ "$MIGRATE_RAN_M5" -eq 1 ]; then
            echo "  cp $MIGRATE_BACKUP_DIR/config.yaml.pre-m5 $EDIKT_ROOT/config.yaml"
        fi
    fi
    return 0
}

# ─── Safe-removal helpers ─────────────────────────────────────────────────────
_dir_is_empty() {
    _d="$1"
    [ -d "$_d" ] || return 1
    for _e in "$_d"/* "$_d"/.[!.]* "$_d"/..?*; do
        [ -e "$_e" ] || [ -L "$_e" ] || continue
        return 1
    done
    return 0
}

_safe_remove_or_quarantine() {
    _tgt="$1"
    _reason="${2:-migrate-abort}"
    if [ ! -e "$_tgt" ] && [ ! -L "$_tgt" ]; then
        return 0
    fi
    if [ -L "$_tgt" ]; then
        rm -f "$_tgt" 2>/dev/null || return 1
        return 0
    fi
    if [ -f "$_tgt" ]; then
        rm -f "$_tgt" 2>/dev/null || return 1
        return 0
    fi
    if [ -d "$_tgt" ] && _dir_is_empty "$_tgt"; then
        rmdir "$_tgt" 2>/dev/null || rm -rf "$_tgt" 2>/dev/null || return 1
        return 0
    fi
    _quar="$_tgt.aborted-$(ts_now)-$$"
    if mv "$_tgt" "$_quar" 2>/dev/null; then
        log_warn "$_reason: refusing to rm-rf non-empty $_tgt — renamed to $_quar for human review"
        return 0
    fi
    log_err "$_reason: could not quarantine $_tgt (mv failed); leaving in place"
    return 1
}

_verify_backup_tarball() {
    _bk="$1"
    _tar="$_bk/pre-migration.tar.gz"
    [ -f "$_tar" ] || return 1
    tar -tzf "$_tar" >/dev/null 2>&1 || return 1
    if [ -f "$_tar.sha256" ]; then
        _obs=$(sha256_file "$_tar" 2>/dev/null) || return 1
        verify_against_sidecar "$_obs" "$_tar.sha256" "$_tar.sha256" >/dev/null 2>&1 \
            || return 1
    fi
    return 0
}

_find_latest_backup_dir() {
    _latest=""
    for _b in "$EDIKT_ROOT"/backups/migration-*; do
        [ -d "$_b" ] || continue
        if _verify_backup_tarball "$_b"; then
            _latest="$_b"
        fi
    done
    [ -n "$_latest" ] && printf '%s\n' "$_latest"
}

migrate_restore_from_predir() {
    pre="$1"
    [ -d "$pre" ] || return 0
    for entry in hooks templates commands VERSION CHANGELOG.md; do
        src="$pre/$entry"
        dst="$EDIKT_ROOT/$entry"
        if [ -e "$src" ] || [ -L "$src" ]; then
            if [ -L "$dst" ]; then
                rm -f "$dst" 2>/dev/null || true
            elif [ -d "$dst" ]; then
                if _dir_is_empty "$dst"; then
                    rmdir "$dst" 2>/dev/null || true
                else
                    _conflict="$dst.conflict-$(ts_now)-$$"
                    if mv "$dst" "$_conflict" 2>/dev/null; then
                        log_warn "migrate_restore_from_predir: refusing to rm-rf non-empty $dst — renamed to $_conflict for human review"
                    else
                        log_err "migrate_restore_from_predir: could not quarantine $dst; skipping entry $entry"
                        continue
                    fi
                fi
            elif [ -e "$dst" ]; then
                rm -f "$dst" 2>/dev/null || true
            fi
            mv "$src" "$dst" 2>/dev/null || true
        fi
    done
    rmdir "$pre" 2>/dev/null || true
}

find_migration_leftovers() {
    for d in "$EDIKT_ROOT"/.migrate-staging-* "$EDIKT_ROOT"/.pre-migration-*; do
        [ -e "$d" ] || continue
        echo "$d"
    done
}

migrate_abort() {
    _any=0

    _have_predir=0
    for pre in "$EDIKT_ROOT"/.pre-migration-*; do
        [ -d "$pre" ] && { _have_predir=1; break; }
    done
    _have_staging=0
    for stg in "$EDIKT_ROOT"/.migrate-staging-*; do
        [ -d "$stg" ] && { _have_staging=1; break; }
    done

    _will_touch_versions=0
    if [ -n "${MIGRATE_VERSION:-}" ] \
        && [ -d "$EDIKT_ROOT/versions/$MIGRATE_VERSION" ] \
        && [ "$_have_predir" -eq 1 ]; then
        _will_touch_versions=1
    fi

    if [ "$_have_predir" -eq 1 ] || [ "$_will_touch_versions" -eq 1 ]; then
        _bk_dir=$(_find_latest_backup_dir)
        if [ -z "$_bk_dir" ]; then
            log_err "migrate-abort: no readable backup tarball found under $EDIKT_ROOT/backups/migration-*"
            log_err "migrate-abort: refusing to mutate state without a verified backup"
            log_err "migrate-abort: inspect $EDIKT_ROOT/.pre-migration-*/ and $EDIKT_ROOT/versions/ manually"
            return 1
        fi
        log_info "migrate-abort: verified backup at $_bk_dir/pre-migration.tar.gz"
    fi

    for pre in "$EDIKT_ROOT"/.pre-migration-*; do
        [ -d "$pre" ] || continue
        _any=1
        log_info "migrate-abort: restoring flat layout from $(basename "$pre")"
        for link in "$EDIKT_ROOT/current" "$EDIKT_ROOT/hooks" "$EDIKT_ROOT/templates"; do
            if [ -L "$link" ]; then
                rm -f "$link" 2>/dev/null || true
            fi
        done
        if [ -n "${MIGRATE_VERSION:-}" ] && [ -d "$EDIKT_ROOT/versions/$MIGRATE_VERSION" ]; then
            _safe_remove_or_quarantine "$EDIKT_ROOT/versions/$MIGRATE_VERSION" "migrate-abort" \
                || log_err "migrate-abort: versions/$MIGRATE_VERSION could not be moved aside; continuing"
            _dir_is_empty "$EDIKT_ROOT/versions" \
                && rmdir "$EDIKT_ROOT/versions" 2>/dev/null || true
        fi
        if [ -n "${MIGRATE_VERSION:-}" ] && [ -f "$EDIKT_ROOT/lock.yaml" ]; then
            _active=$(lock_get active)
            if [ "$_active" = "$MIGRATE_VERSION" ]; then
                rm -f "$EDIKT_ROOT/lock.yaml" 2>/dev/null || true
            fi
        fi
        migrate_restore_from_predir "$pre"
    done

    for stg in "$EDIKT_ROOT"/.migrate-staging-*; do
        [ -d "$stg" ] || continue
        _any=1
        log_info "migrate-abort: removing staging $(basename "$stg")"
        rm -rf "$stg" 2>/dev/null || true
    done

    if [ "$_any" -eq 1 ]; then
        emit_event migration_aborted \
            '"reason":"abort","root":"'"$EDIKT_ROOT"'"'
        log_info "migrate-abort: complete"
    fi
    return 0
}

migrate_trap_handler() {
    _rc="${1:-1}"
    if [ "$MIGRATE_STATE" = "done" ]; then
        release_lock
        return 0
    fi
    MIGRATE_STATE="aborting"
    migrate_abort 2>/dev/null || true
    release_lock
    case "$_rc" in
        130|143) exit "$_rc" ;;
        *) ;;
    esac
}

# ─── Subcommand: migrate ──────────────────────────────────────────────────────
MIGRATE_STATE="idle"
MIGRATE_TS=""
MIGRATE_STAGING=""
MIGRATE_PREDIR=""
MIGRATE_BACKUP_DIR=""
MIGRATE_VERSION=""

cmd_migrate() {
    dry_run=0
    assume_yes=0
    abort_only=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --dry-run) dry_run=1 ;;
            --yes|-y)  assume_yes=1 ;;
            --abort)   abort_only=1 ;;
            -h|--help)
                cat <<EOF
Usage: edikt migrate [--dry-run] [--yes] [--abort]

Migrate a pre-v0.5.0 flat layout (hooks/ as directory) into the versioned
layout. Dry-run previews the move plan without mutation. --yes bypasses the
interactive confirmation. --abort restores state from any crashed or
in-progress migration.
EOF
                return 0
                ;;
            *) log_err "unknown flag: $1"; return 1 ;;
        esac
        shift
    done

    if [ "$abort_only" -eq 1 ]; then
        acquire_lock || return $?
        if ! migration_in_progress; then
            release_lock
            log_info "nothing to abort (no staging or pre-migration directory found)"
            return 0
        fi
        migrate_abort
        _abort_rc=$?
        release_lock
        return "$_abort_rc"
    fi

    if ! needs_migration && migration_in_progress; then
        log_warn "partial migration detected. Run: edikt migrate --abort"
        return 1
    fi

    if ! needs_migration; then
        _has_signal=0
        if [ -f "$EDIKT_ROOT/CLAUDE.md" ] \
           && grep -q '<!-- edikt:start -->' "$EDIKT_ROOT/CLAUDE.md" 2>/dev/null \
           && grep -q '<!-- edikt:end -->' "$EDIKT_ROOT/CLAUDE.md" 2>/dev/null; then
            _has_signal=1
        fi
        if [ "$_has_signal" -eq 0 ] \
           && [ -d "$CLAUDE_ROOT/commands/edikt" ] \
           && [ -d "$EDIKT_ROOT/current/commands/edikt" ]; then
            for _f in "$CLAUDE_ROOT"/commands/edikt/*.md; do
                [ -f "$_f" ] || continue
                [ -L "$_f" ] && continue
                _b=$(basename "$_f")
                if find "$EDIKT_ROOT/current/commands/edikt" -mindepth 2 -type f -name "$_b" 2>/dev/null | grep -q .; then
                    _has_signal=1
                    break
                fi
            done
        fi
        if [ "$_has_signal" -eq 0 ] && [ -f "$EDIKT_ROOT/config.yaml" ]; then
            for _k in '^paths:' '^stack:' '^gates:'; do
                if ! grep -q "$_k" "$EDIKT_ROOT/config.yaml" 2>/dev/null; then
                    _has_signal=1
                    break
                fi
            done
        fi
        if [ "$_has_signal" -eq 0 ] \
           && [ -f "$CLAUDE_ROOT/rules/governance.md" ] \
           && ! grep -q 'compile_schema_version: 2' "$CLAUDE_ROOT/rules/governance.md" 2>/dev/null \
           && [ ! -f "$EDIKT_ROOT/.m4-pending" ]; then
            _has_signal=1
        fi

        if [ "$_has_signal" -eq 0 ]; then
            log_info "No migration needed."
            return 0
        fi

        if [ "$dry_run" -eq 1 ]; then
            echo "Migration plan (dry-run):"
            _run_secondary_migrations 1
            echo ""
            echo "(dry-run: no changes written)"
            return 0
        fi
        acquire_lock || return $?
        MIGRATE_TS=$(ts_now)
        _run_secondary_migrations 0
        _rc=$?
        release_lock
        if [ "$_rc" -ne 0 ]; then
            emit_event migration_partial_failure \
                '"step":"secondary","rc":'"$_rc"',"backup":"'"${MIGRATE_BACKUP_DIR:-}"'"'
            log_err "secondary migration(s) failed (rc=$_rc). Backups at ${MIGRATE_BACKUP_DIR:-$EDIKT_ROOT/backups/}/. Re-run 'edikt migrate' to retry, or 'edikt doctor' to inspect."
            return "$_rc"
        fi
        echo ""
        echo "Migration complete."
        echo ""
        echo "Migration summary:"
        _print_secondary_summary
        return 0
    fi

    MIGRATE_VERSION=$(head -1 "$EDIKT_ROOT/VERSION" | tr -d '[:space:]')
    if [ -z "$MIGRATE_VERSION" ]; then
        log_err "cannot read version from $EDIKT_ROOT/VERSION"
        return 1
    fi
    case "$MIGRATE_VERSION" in
        *[!0-9A-Za-z._-]* | *..* | /* | */* | .* | -*)
            log_err "refusing to migrate: VERSION ($MIGRATE_VERSION) is not a valid semver-ish identifier"
            return 1
            ;;
    esac
    if ! printf '%s' "$MIGRATE_VERSION" \
        | awk '/^[0-9]+\.[0-9]+\.[0-9]+([.-][A-Za-z0-9]+)*$/ {ok=1} END {exit !ok}'; then
        log_err "refusing to migrate: VERSION ($MIGRATE_VERSION) does not match semver pattern"
        return 1
    fi

    echo "Migration needed: flat layout → versioned layout (target: $MIGRATE_VERSION)"
    echo ""
    echo "Will move:"
    for entry in hooks templates commands VERSION CHANGELOG.md; do
        if [ -e "$EDIKT_ROOT/$entry" ] || [ -L "$EDIKT_ROOT/$entry" ]; then
            echo "  $EDIKT_ROOT/$entry  →  $EDIKT_ROOT/versions/$MIGRATE_VERSION/$entry"
        fi
    done
    echo ""
    echo "Will create symlinks:"
    echo "  $EDIKT_ROOT/current      → versions/$MIGRATE_VERSION"
    echo "  $EDIKT_ROOT/hooks        → current/hooks"
    echo "  $EDIKT_ROOT/templates    → current/templates"
    echo "  $CLAUDE_ROOT/commands/edikt → $EDIKT_ROOT/current/commands"
    echo ""
    echo "Will preserve:"
    for entry in config.yaml custom backups events.jsonl lock.yaml; do
        if [ -e "$EDIKT_ROOT/$entry" ]; then
            echo "  $EDIKT_ROOT/$entry (untouched)"
        fi
    done
    echo ""
    echo "Backup:"
    echo "  $EDIKT_ROOT/backups/migration-<ts>/pre-migration.tar.gz"
    echo "  $EDIKT_ROOT/backups/migration-<ts>/pre-migration.tar.gz.sha256"
    echo "  (use 'edikt migrate --abort' to restore from the most recent backup)"
    echo ""

    if [ "$dry_run" -eq 1 ]; then
        echo "Secondary migrations (M2-M6) — detection plan:"
        _run_secondary_migrations 1
        echo ""
        echo "(dry-run: no changes written)"
        return 0
    fi

    if [ "$assume_yes" -ne 1 ]; then
        if { [ ! -r /dev/tty ] || [ ! -t 0 ]; } && [ ! -c /dev/tty ]; then
            log_err "non-interactive session detected. Re-run with --yes to confirm migration."
            return 1
        fi
        printf 'Proceed? [y/N]: ' >/dev/tty 2>/dev/null || printf 'Proceed? [y/N]: ' >&2
        if ! read -r reply </dev/tty 2>/dev/null; then
            log_err "cannot read from /dev/tty. Re-run with --yes."
            return 1
        fi
        case "$reply" in
            y|Y|yes|YES) ;;
            *) log_info "aborted"; return 0 ;;
        esac
    fi

    acquire_lock || return $?

    MIGRATE_STATE="starting"
    MIGRATE_TS=$(ts_now)
    MIGRATE_STAGING="$EDIKT_ROOT/.migrate-staging-$MIGRATE_TS-$$"
    MIGRATE_PREDIR="$EDIKT_ROOT/.pre-migration-$MIGRATE_TS-$$"
    MIGRATE_BACKUP_DIR="$EDIKT_ROOT/backups/migration-$MIGRATE_TS-$$"

    mkdir -p "$MIGRATE_BACKUP_DIR" || return 1
    set --
    for entry in hooks templates commands VERSION CHANGELOG.md; do
        if [ -e "$EDIKT_ROOT/$entry" ] || [ -L "$EDIKT_ROOT/$entry" ]; then
            set -- "$@" "$entry"
        fi
    done
    if [ "$#" -eq 0 ]; then
        log_err "no legacy layout entries found to back up"
        return 1
    fi
    if ! ( cd "$EDIKT_ROOT" && tar -czf "$MIGRATE_BACKUP_DIR/pre-migration.tar.gz" "$@" 2>/dev/null ); then
        log_err "failed to create pre-migration backup tarball"
        return 1
    fi
    if ! tar -tzf "$MIGRATE_BACKUP_DIR/pre-migration.tar.gz" >/dev/null 2>&1; then
        log_err "pre-migration backup tarball is not readable"
        return 1
    fi
    _bk_hash=$(sha256_file "$MIGRATE_BACKUP_DIR/pre-migration.tar.gz") || {
        log_err "failed to compute backup sha256"
        return 1
    }
    printf '%s  pre-migration.tar.gz\n' "$_bk_hash" \
        >"$MIGRATE_BACKUP_DIR/pre-migration.tar.gz.sha256" || {
        log_err "failed to write backup sha256 sidecar"
        return 1
    }
    log_info "migrate: wrote pre-migration backup to $MIGRATE_BACKUP_DIR/pre-migration.tar.gz"

    if ! mkdir "$MIGRATE_STAGING" 2>/dev/null; then
        log_err "staging dir already exists: $MIGRATE_STAGING"
        return 1
    fi
    stage_version_dir="$MIGRATE_STAGING/$MIGRATE_VERSION"
    mkdir "$stage_version_dir" || return 1
    for entry in hooks templates commands VERSION CHANGELOG.md; do
        src="$EDIKT_ROOT/$entry"
        [ -e "$src" ] || [ -L "$src" ] || continue
        if [ -d "$src" ] && [ ! -L "$src" ]; then
            ( cd "$EDIKT_ROOT" && tar -cf - "$entry" ) | ( cd "$stage_version_dir" && tar -xf - ) \
                || { log_err "failed to copy $entry into staging"; return 1; }
        else
            cp "$src" "$stage_version_dir/$entry" || { log_err "failed to copy $entry"; return 1; }
        fi
    done

    write_manifest "$stage_version_dir" "$MIGRATE_VERSION" "migration" "" ""

    if ! manifest_verify "$stage_version_dir" >/dev/null 2>&1; then
        log_err "staged manifest verification failed"
        return 1
    fi

    MIGRATE_STATE="swapping"

    mkdir "$MIGRATE_PREDIR" || return 1
    for entry in hooks templates commands VERSION CHANGELOG.md; do
        src="$EDIKT_ROOT/$entry"
        if [ -e "$src" ] || [ -L "$src" ]; then
            mv "$src" "$MIGRATE_PREDIR/$entry" || {
                log_err "failed to move $entry sideways — will be restored by abort"
                return 1
            }
        fi
    done

    mkdir -p "$EDIKT_ROOT/versions"
    if [ -e "$EDIKT_ROOT/versions/$MIGRATE_VERSION" ]; then
        log_err "versions/$MIGRATE_VERSION already exists — refusing to overwrite"
        return 1
    fi
    mv "$stage_version_dir" "$EDIKT_ROOT/versions/$MIGRATE_VERSION" \
        || { log_err "failed to move staged version into place"; return 1; }

    atomic_symlink "versions/$MIGRATE_VERSION" "$EDIKT_ROOT/current" \
        || { log_err "failed to create current symlink"; return 1; }
    ensure_external_symlinks

    lock_write "$MIGRATE_VERSION" "migration"

    emit_event layout_migrated \
        '"from":"flat","to":"versioned","version":"'"$MIGRATE_VERSION"'","backup":"'"$MIGRATE_BACKUP_DIR"'"'

    MIGRATE_STATE="done"
    rm -rf "$MIGRATE_PREDIR" 2>/dev/null || true
    rm -rf "$MIGRATE_STAGING" 2>/dev/null || true

    log_info "migration complete: $MIGRATE_VERSION activated"

    _sec_rc=0
    _run_secondary_migrations 0 || _sec_rc=$?
    if [ "$_sec_rc" -ne 0 ]; then
        emit_event migration_partial_failure \
            '"step":"secondary","rc":'"$_sec_rc"',"backup":"'"$MIGRATE_BACKUP_DIR"'"'
        log_err "secondary migration(s) failed (rc=$_sec_rc). Backups at $MIGRATE_BACKUP_DIR/. Re-run 'edikt migrate' to retry."
        echo ""
        echo "Migration summary (partial — M1 succeeded, secondary step(s) failed):"
        echo "  M1: flat → versioned (target $MIGRATE_VERSION)"
        _print_secondary_summary
        return "$_sec_rc"
    fi
    echo ""
    echo "Migration complete."
    echo ""
    echo "Migration summary:"
    echo "  M1: flat → versioned (target $MIGRATE_VERSION)"
    _print_secondary_summary
    return 0
}

# ─── Dispatch ─────────────────────────────────────────────────────────────────
sub="${1:-help}"
shift 2>/dev/null || true

case "$sub" in
    migrate) cmd_migrate "$@" ;;
    help|--help|-h|"")
        cat <<EOF
edikt-shell — migrate-only helper (ADR-022)

Usage: edikt migrate [--dry-run] [--yes] [--abort]

All other subcommands have moved to the Go edikt binary.
Run \`edikt --help\` for the full command reference.
EOF
        ;;
    *)
        echo "error: this command has moved to the Go binary — run \`edikt $sub\`" >&2
        exit 1
        ;;
esac
