#!/bin/sh
# edikt launcher — POSIX shell. INV-001: no compiled code, no build step.
#
# Implements SPEC-004 v0.5.0: versioned on-disk layout, generation symlink
# chain, lock.yaml + manifest.yaml, atomic flips, flock serialization.
#
# Subcommands: version | list | install | use | rollback | doctor | uninstall
#
# Strict POSIX: no bashisms, no [[ ]], no arrays, no `source`. Verified via
# `sh -n bin/edikt`. Tested under /bin/sh (dash on Linux, bash 3.2 on macOS).

set -u

umask 022

# ─── Constants ──────────────────────────────────────────────────────────────
LAUNCHER_VERSION="0.5.0"
MIN_PAYLOAD_VERSION="0.5.0"
RELEASE_TARBALL_BASE="https://github.com/diktahq/edikt/archive/refs/tags"

# Exit codes (per SPEC-004 §2)
EX_OK=0
EX_NETWORK=1
EX_CHECKSUM=2
EX_ALREADY=3
EX_LOCKED=4
EX_MALICIOUS=5

# Event log rotation threshold (10 MiB per config-spec §4.4)
EVENTS_MAX_BYTES=10485760

# ─── EDIKT_ROOT resolution ──────────────────────────────────────────────────
# Priority: explicit env > project mode (ancestor walk for .edikt/bin/edikt)
# > global mode ($HOME/.edikt). Project mode is wired here so Phase 8 only
# adds its surface, not a rewrite of every subcommand.
resolve_edikt_root() {
    if [ -n "${EDIKT_ROOT:-}" ]; then
        echo "$EDIKT_ROOT"
        return 0
    fi
    # Walk upward looking for .edikt/bin/edikt (project-mode marker).
    dir="$PWD"
    while [ -n "$dir" ] && [ "$dir" != "/" ]; do
        if [ -x "$dir/.edikt/bin/edikt" ]; then
            echo "$dir/.edikt"
            return 0
        fi
        dir=$(dirname "$dir")
    done
    # Global mode. EDIKT_HOME for Phase 1 sandbox compatibility.
    if [ -n "${EDIKT_HOME:-}" ]; then
        echo "$EDIKT_HOME"
    else
        echo "${HOME:-/}/.edikt"
    fi
}

resolve_claude_root() {
    if [ -n "${CLAUDE_HOME:-}" ]; then
        echo "$CLAUDE_HOME"
    else
        echo "${HOME:-/}/.claude"
    fi
}

EDIKT_ROOT=$(resolve_edikt_root)
CLAUDE_ROOT=$(resolve_claude_root)

# ─── SHA256 dispatch (per config-spec §7) ───────────────────────────────────
sha256_file() {
    f="$1"
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$f" | awk '{print $1}'
    elif command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$f" | awk '{print $1}'
    else
        echo "error: need sha256sum or shasum" >&2
        return 1
    fi
}

# ─── Sidecar checksum verification ──────────────────────────────────────────
# Verifies an observed sha256 against a reference file. Reference may be a
# bare hex hash or "<hash>  <filename>" (standard sha256sum/shasum output).
# Arguments: observed_hash, reference_file_path, reference_label (for errors).
# Returns 0 on match, non-zero on empty/mismatched reference. Logs to stderr.
verify_against_sidecar() {
    _observed="$1"
    _ref_file="$2"
    _ref_label="$3"
    _expected=$(awk '{print $1; exit}' "$_ref_file" 2>/dev/null | tr -d '[:space:]')
    if [ -z "$_expected" ]; then
        log_err "checksum reference $_ref_label is empty"
        return 1
    fi
    if [ "$_observed" != "$_expected" ]; then
        log_err "checksum mismatch: reference $_ref_label expected $_expected, got $_observed"
        return 1
    fi
    return 0
}

# ─── Tarball entry safety (path-traversal guard) ────────────────────────────
# Returns 0 if every entry in the tarball is a safe relative path, 1 if any
# entry is absolute or contains a `..` path component. BSD tar on macOS does
# NOT strip `../` entries during extraction, so the launcher must pre-scan.
tarball_safe() {
    tf="$1"
    tar -tzf "$tf" 2>/dev/null | while IFS= read -r entry; do
        # Strip trailing slash for directory entries.
        case "$entry" in
            "") continue ;;
            /*)
                printf 'unsafe-absolute: %s\n' "$entry" >&2
                exit 1
                ;;
            ../*|*/../*|*/..)
                printf 'unsafe-traversal: %s\n' "$entry" >&2
                exit 1
                ;;
        esac
    done
    # `while` runs in a subshell under POSIX pipelines — its exit status
    # propagates as the pipeline's final status. 0 means all entries safe.
}

# ─── ISO-8601 UTC timestamp (portable BSD + GNU date) ───────────────────────
iso_now() {
    date -u +%Y-%m-%dT%H:%M:%SZ
}

# Compact timestamp suitable for directory names.
ts_now() {
    date -u +%Y%m%dT%H%M%SZ
}

# ─── Logging ────────────────────────────────────────────────────────────────
log_info() { echo "$@" >&2; }
log_warn() { echo "warn: $*" >&2; }
log_err()  { echo "error: $*" >&2; }

# ─── flock serialization (per config-spec §8.1, §8.8 NFS fallback) ──────────
# Acquires an exclusive lock under $EDIKT_ROOT/.lock for the lifetime of
# the calling shell. Falls back to mkdir-based mutex when flock(1) absent
# (e.g. macOS without util-linux). NFS ENOLCK → ln -s create-link mutex.
LOCK_HELD=""
LOCK_DIR=""
LOCK_FD=""

acquire_lock() {
    mkdir -p "$EDIKT_ROOT" || return 1
    lockfile="$EDIKT_ROOT/.lock"

    if command -v flock >/dev/null 2>&1; then
        # Use file descriptor 9 with flock -n (non-blocking).
        # Errors during flock indicate ENOLCK on NFS; fall through.
        if (
            exec 9>"$lockfile" 2>/dev/null
            flock -n 9 2>/dev/null
        ); then
            # We need the lock held for the lifetime of THIS shell, not a
            # subshell. POSIX `exec N>` works here.
            exec 9>"$lockfile"
            if flock -n 9 2>/dev/null; then
                LOCK_HELD="flock"
                LOCK_FD=9
                printf '%s %s\n' "$$" "$(iso_now)" >&9
                return 0
            fi
            # flock failed after open: another process holds it.
            log_err "another edikt process is running (lock: $lockfile). Retry or remove stale lock."
            return 4
        fi
        # flock unavailable on this fs (NFS ENOLCK) → fallback.
    fi

    # mkdir mutex fallback (macOS without util-linux, NFS).
    LOCK_DIR="$EDIKT_ROOT/.lock.d"
    if ! mkdir "$LOCK_DIR" 2>/dev/null; then
        # Check if the existing lockdir is stale (owner pid is dead).
        # If the owner file is missing, assume a live holder is mid-write
        # and do NOT reclaim — avoids racing a peer between mkdir and the
        # owner-file write below.
        stale=0
        if [ -f "$LOCK_DIR/owner" ]; then
            owner_pid=$(awk '{print $1; exit}' "$LOCK_DIR/owner" 2>/dev/null)
            if [ -n "$owner_pid" ] && ! kill -0 "$owner_pid" 2>/dev/null; then
                stale=1
            fi
        fi
        if [ "$stale" -eq 1 ]; then
            log_warn "reclaiming stale lock dir $LOCK_DIR"
            rm -rf "$LOCK_DIR" 2>/dev/null || true
            if ! mkdir "$LOCK_DIR" 2>/dev/null; then
                log_err "another edikt process is running (lock dir: $LOCK_DIR). Retry or remove stale lock."
                return 4
            fi
        else
            log_err "another edikt process is running (lock dir: $LOCK_DIR). Retry or remove stale lock."
            return 4
        fi
    fi
    printf '%s %s\n' "$$" "$(iso_now)" >"$LOCK_DIR/owner" 2>/dev/null || true
    LOCK_HELD="mkdir"
    return 0
}

release_lock() {
    if [ "$LOCK_HELD" = "mkdir" ] && [ -n "$LOCK_DIR" ]; then
        rm -rf "$LOCK_DIR" 2>/dev/null || true
    elif [ "$LOCK_HELD" = "flock" ] && [ -n "$LOCK_FD" ]; then
        # Closing FD 9 releases the flock automatically.
        exec 9>&- 2>/dev/null || true
    fi
    LOCK_HELD=""
}

# Single global exit dispatcher. When a migration is in flight
# (MIGRATE_STATE ∈ {starting, swapping, aborting}), delegate to the
# migrate trap handler FIRST — it restores on-disk state — then always
# release the lock. Refactored from an in-cmd_migrate trap-swap
# (review finding #17) so future global cleanup additions cannot be
# silently swallowed by cmd_migrate's override.
edikt_exit_trap() {
    _rc=$?
    _signum="${1:-}"
    case "${MIGRATE_STATE:-}" in
        ""|idle|done) ;;
        *)
            case "$_signum" in
                INT)  _rc=130 ;;
                TERM) _rc=143 ;;
            esac
            migrate_trap_handler "$_rc" 2>/dev/null || true
            ;;
    esac
    release_lock
    return "$_rc"
}
trap 'edikt_exit_trap' EXIT
trap 'edikt_exit_trap INT'  INT
trap 'edikt_exit_trap TERM' TERM

# ─── Atomic write helper ────────────────────────────────────────────────────
# usage: atomic_write <dest> <<EOF ... EOF
atomic_write() {
    dest="$1"
    tmp="$dest.tmp.$$"
    cat >"$tmp" || { rm -f "$tmp"; return 1; }
    mv -f "$tmp" "$dest"
}

# ─── Event emission to events.jsonl (per config-spec §4.4) ──────────────────
# usage: emit_event <type> '<extra-json-fields>'
# extra-fields is the JSON middle (no surrounding braces, no leading comma).
emit_event() {
    typ="$1"
    extra="${2:-}"
    mkdir -p "$EDIKT_ROOT" 2>/dev/null || return 0
    line='{"event":"'"$typ"'","timestamp":"'"$(iso_now)"'"'
    if [ -n "$extra" ]; then
        line="$line,$extra"
    fi
    line="$line}"
    # Rotate if the existing log would exceed the threshold after append.
    evlog="$EDIKT_ROOT/events.jsonl"
    if [ -f "$evlog" ]; then
        cur_sz=0
        if stat -f '%z' "$evlog" >/dev/null 2>&1; then
            cur_sz=$(stat -f '%z' "$evlog" 2>/dev/null || echo 0)
        elif stat -c '%s' "$evlog" >/dev/null 2>&1; then
            cur_sz=$(stat -c '%s' "$evlog" 2>/dev/null || echo 0)
        fi
        # Add line length + 1 (newline) for conservative threshold check.
        add_sz=$(( ${#line} + 1 ))
        if [ $(( cur_sz + add_sz )) -gt "$EVENTS_MAX_BYTES" ]; then
            mv -f "$evlog" "$evlog.1" 2>/dev/null || true
        fi
    fi
    # Single printf, single line — atomic on POSIX up to PIPE_BUF.
    printf '%s\n' "$line" >>"$evlog"
}

# ─── Version comparison (semver, no leading v) ──────────────────────────────
# Returns 0 if $1 >= $2, 1 otherwise. Plain dot-separated integers only.
version_ge() {
    a="$1"
    b="$2"
    a_norm=$(echo "$a" | sed 's/^v//')
    b_norm=$(echo "$b" | sed 's/^v//')
    # Awk-based comparison handles arbitrary segment counts.
    awk -v a="$a_norm" -v b="$b_norm" 'BEGIN {
        na = split(a, A, /\./)
        nb = split(b, B, /\./)
        n = (na > nb) ? na : nb
        for (i = 1; i <= n; i++) {
            ai = (i in A) ? A[i] + 0 : 0
            bi = (i in B) ? B[i] + 0 : 0
            if (ai > bi) exit 0
            if (ai < bi) exit 1
        }
        exit 0
    }'
}

normalize_tag() {
    echo "$1" | sed 's/^v//'
}

# ─── lock.yaml read helpers ─────────────────────────────────────────────────
# Plain-text YAML reader for the small subset we write. Only top-level
# scalar keys are supported (active, previous, installed_at, installed_via).
# History entries are treated opaquely — append-only.
lock_get() {
    key="$1"
    f="$EDIKT_ROOT/lock.yaml"
    [ -f "$f" ] || return 0
    awk -v k="$key" '
        $0 ~ "^"k":" {
            sub("^"k":[ \t]*", "")
            gsub(/^["\047]|["\047]$/, "")
            print
            exit
        }
    ' "$f"
}

# ─── lock.yaml write (atomic) ───────────────────────────────────────────────
# Writes/updates active+previous+installed_at+installed_via, appends a new
# history entry. Existing history is preserved (capped at 50 per config-spec).
lock_write() {
    new_active="$1"
    new_installed_via="$2"
    now=$(iso_now)
    f="$EDIKT_ROOT/lock.yaml"

    prev_active=$(lock_get active)
    # Build the new file in a temp and move atomically.
    tmp="$f.tmp.$$"
    {
        printf 'active: "%s"\n' "$new_active"
        if [ -n "$prev_active" ] && [ "$prev_active" != "$new_active" ]; then
            printf 'previous: "%s"\n' "$prev_active"
        elif [ -n "$(lock_get previous)" ]; then
            printf 'previous: "%s"\n' "$(lock_get previous)"
        fi
        printf 'installed_at: "%s"\n' "$now"
        printf 'installed_via: "%s"\n' "$new_installed_via"
        printf 'history:\n'
        # Preserve existing history entries (best-effort), cap at 49 to make
        # room for the new one.
        if [ -f "$f" ]; then
            awk '
                /^history:/ { in_hist = 1; next }
                in_hist && /^[a-zA-Z]/ { in_hist = 0 }
                in_hist { print }
            ' "$f" | head -98
        fi
        printf '  - version: "%s"\n' "$new_active"
        printf '    installed_at: "%s"\n' "$now"
        printf '    activated_at: "%s"\n' "$now"
        printf '    installed_via: "%s"\n' "$new_installed_via"
    } >"$tmp"
    mv -f "$tmp" "$f"
}

# ─── Symlink chain helpers ──────────────────────────────────────────────────
# The chain (per SPEC §1):
#   $EDIKT_ROOT/current        -> versions/<tag>
#   $EDIKT_ROOT/hooks          -> current/hooks
#   $EDIKT_ROOT/templates      -> current/templates
#   $CLAUDE_ROOT/commands/edikt -> $EDIKT_ROOT/current/commands/edikt
# Atomic symlink install: create a sibling `.new` symlink then rename(2)
# it over the target. rename(2) on a symlink is atomic on every POSIX
# filesystem, closing the ln -sfn unlink-then-create window where a
# concurrent hook could see ENOENT.
atomic_symlink() {
    target="$1"
    link="$2"
    new="$link.new.$$"
    rm -f "$new" 2>/dev/null || true
    ln -s "$target" "$new" || return 1
    # mv -f on a symlink-to-directory target traverses into the directory
    # on BSD and GNU alike. Use -h (BSD) or -T (GNU) to force treatment
    # as a regular link rename. If neither flag is available, fall back
    # to `ln -sfn` — not perfectly atomic, but the same behavior as the
    # prior implementation.
    if mv -hf "$new" "$link" 2>/dev/null; then
        return 0
    fi
    if mv -Tf "$new" "$link" 2>/dev/null; then
        return 0
    fi
    rm -f "$new" 2>/dev/null || true
    ln -sfn "$target" "$link"
}

ensure_external_symlinks() {
    # hooks and templates are stable external paths embedded in
    # settings.json. Repair on every install/use.
    atomic_symlink current/hooks "$EDIKT_ROOT/hooks"
    atomic_symlink current/templates "$EDIKT_ROOT/templates"
    mkdir -p "$CLAUDE_ROOT/commands"
    atomic_symlink "$EDIKT_ROOT/current/commands/edikt" "$CLAUDE_ROOT/commands/edikt"
}

# Atomic symlink flip: ln -sfn replaces an existing symlink in one
# rename(2) on most filesystems. Snapshots prior target into backups/<ts>/.
flip_current() {
    target="$1"  # e.g. versions/0.5.0
    ts=$(ts_now)
    backup_dir="$EDIKT_ROOT/backups/$ts"
    mkdir -p "$backup_dir"

    if [ -L "$EDIKT_ROOT/current" ]; then
        prior=$(readlink "$EDIKT_ROOT/current")
        printf '%s\n' "$prior" >"$backup_dir/prior_target"
    fi

    atomic_symlink "$target" "$EDIKT_ROOT/current"
    ensure_external_symlinks

    echo "$ts"
}

# ─── manifest.yaml writer (per config-spec §4.2) ────────────────────────────
write_manifest() {
    version_dir="$1"
    version="$2"
    source_type="$3"
    source_url="$4"
    tarball_sha="$5"

    manifest="$version_dir/manifest.yaml"
    tmp="$manifest.tmp.$$"
    {
        printf 'version: "%s"\n' "$version"
        printf 'installed_at: "%s"\n' "$(iso_now)"
        printf 'source:\n'
        printf '  type: "%s"\n' "$source_type"
        if [ -n "$source_url" ]; then
            printf '  url: "%s"\n' "$source_url"
        fi
        if [ -n "$tarball_sha" ]; then
            printf '  sha256: "%s"\n' "$tarball_sha"
        fi
        printf 'files:\n'
        # Walk the version dir and hash every regular file (excluding
        # manifest.yaml itself which we're writing now).
        ( cd "$version_dir" && find . -type f \
            ! -name 'manifest.yaml' \
            ! -name 'manifest.yaml.tmp.*' \
            | sed 's|^\./||' | LC_ALL=C sort ) | while IFS= read -r relpath; do
            sha=$(sha256_file "$version_dir/$relpath") || continue
            mode=$(stat_mode "$version_dir/$relpath")
            printf '  - path: "%s"\n' "$relpath"
            printf '    sha256: "%s"\n' "$sha"
            printf '    mode: "%s"\n' "$mode"
        done
    } >"$tmp"
    mv -f "$tmp" "$manifest"
}

# Portable file mode (octal). BSD vs GNU stat differ.
stat_mode() {
    f="$1"
    if stat -f '%Lp' "$f" >/dev/null 2>&1; then
        # BSD (macOS)
        printf '0%s' "$(stat -f '%Lp' "$f")"
    elif stat -c '%a' "$f" >/dev/null 2>&1; then
        # GNU
        printf '0%s' "$(stat -c '%a' "$f")"
    else
        printf '0644'
    fi
}

# ─── manifest verify ────────────────────────────────────────────────────────
# Returns 0 if every file recorded in manifest.yaml matches its sha256,
# 1 otherwise. Writes mismatches to stderr.
manifest_verify() {
    version_dir="$1"
    manifest="$version_dir/manifest.yaml"
    [ -f "$manifest" ] || { log_err "no manifest at $manifest"; return 1; }

    # Parse path/sha256 pairs into a temp file (pipeline subshell would
    # lose our `bad` counter).
    pairs="$version_dir/.manifest-pairs.$$"
    awk '
        /^  - path:/    { if (match($0, /"[^"]*"/)) path = substr($0, RSTART+1, RLENGTH-2); next }
        /^    sha256:/  { if (match($0, /"[^"]*"/)) print path, substr($0, RSTART+1, RLENGTH-2) }
    ' "$manifest" >"$pairs"

    bad=0
    while read -r p s; do
        [ -n "$p" ] && [ -n "$s" ] || continue
        if [ ! -f "$version_dir/$p" ]; then
            echo "missing: $p" >&2
            bad=1
            continue
        fi
        actual=$(sha256_file "$version_dir/$p")
        if [ "$actual" != "$s" ]; then
            echo "tampered: $p (expected $s, got $actual)" >&2
            bad=1
        fi
    done <"$pairs"
    rm -f "$pairs"
    return $bad
}

# ─── MIN_PAYLOAD_VERSION enforcement ────────────────────────────────────────
# Refuse to activate a payload older than MIN_PAYLOAD_VERSION.
check_payload_min_version() {
    payload_dir="$1"
    vfile="$payload_dir/VERSION"
    if [ ! -f "$vfile" ]; then
        log_err "payload at $payload_dir is missing VERSION file"
        return 1
    fi
    payload_v=$(head -1 "$vfile" | tr -d '[:space:]')
    if ! version_ge "$payload_v" "$MIN_PAYLOAD_VERSION"; then
        log_err "payload version $payload_v is older than launcher MIN_PAYLOAD_VERSION ($MIN_PAYLOAD_VERSION)."
        log_err "Run \`edikt install <newer-tag>\` and \`edikt use <newer-tag>\`."
        return 1
    fi
    return 0
}

# ─── Subcommand: version ────────────────────────────────────────────────────
cmd_version() {
    if [ -f "$EDIKT_ROOT/current/VERSION" ]; then
        head -1 "$EDIKT_ROOT/current/VERSION"
    elif [ -n "$(lock_get active)" ]; then
        lock_get active
    else
        echo "no version installed (launcher: $LAUNCHER_VERSION)"
        return 0
    fi
}

# ─── Subcommand: list ───────────────────────────────────────────────────────
cmd_list() {
    verbose=0
    if [ "${1:-}" = "--verbose" ]; then verbose=1; fi

    versions_dir="$EDIKT_ROOT/versions"
    if [ ! -d "$versions_dir" ]; then
        echo "(no versions installed)"
        return 0
    fi
    active_target=""
    if [ -L "$EDIKT_ROOT/current" ]; then
        active_target=$(readlink "$EDIKT_ROOT/current")
        active_target=$(basename "$active_target")
    fi
    # Iterate sorted entries.
    found=0
    for d in "$versions_dir"/*/; do
        [ -d "$d" ] || continue
        found=1
        tag=$(basename "$d")
        marker=" "
        if [ "$tag" = "$active_target" ]; then marker="*"; fi
        if [ "$verbose" -eq 1 ]; then
            sz="?"
            if command -v du >/dev/null 2>&1; then
                sz=$(du -sh "$d" 2>/dev/null | awk '{print $1}')
            fi
            installed=""
            if [ -f "$d/manifest.yaml" ]; then
                installed=$(awk -F'"' '/^installed_at:/ {print $2; exit}' "$d/manifest.yaml")
            fi
            printf '%s %s\t%s\t%s\n' "$marker" "$tag" "${installed:--}" "$sz"
        else
            printf '%s %s\n' "$marker" "$tag"
        fi
    done
    if [ "$found" -eq 0 ]; then
        echo "(no versions installed)"
    fi
}

# ─── Subcommand: install ────────────────────────────────────────────────────
# Fetch tarball, extract to staging, atomic move into versions/<tag>/,
# write manifest.yaml. Does NOT activate. Use `use` to flip.
cmd_install() {
    tag="${1:-}"
    if [ -z "$tag" ]; then
        log_err "usage: edikt install <tag>"
        return 1
    fi
    norm=$(normalize_tag "$tag")
    target="$EDIKT_ROOT/versions/$norm"
    if [ -d "$target" ]; then
        log_err "version $norm is already installed at $target"
        return $EX_ALREADY
    fi

    acquire_lock || return $?

    mkdir -p "$EDIKT_ROOT/versions"
    # Predictable-named directory inside EDIKT_ROOT — use plain mkdir (not
    # -p) and fail loudly if the path already exists (e.g. a pre-planted
    # symlink at the predicted path). Collision is astronomically
    # unlikely with ts+pid but defense-in-depth matters here.
    staging="$EDIKT_ROOT/.staging-$(ts_now)-$$"
    if ! mkdir "$staging" 2>/dev/null; then
        log_err "staging dir already exists or cannot be created: $staging"
        return 1
    fi

    cleanup_staging() { rm -rf "$staging" 2>/dev/null || true; }

    # Allow tests / offline installs to point at a local tarball or dir.
    src="${EDIKT_INSTALL_SOURCE:-}"
    if [ -n "$src" ]; then
        log_warn "EDIKT_INSTALL_SOURCE override active: $src"
    fi
    url=""
    tarball_sha=""

    if [ -z "$src" ]; then
        url="$RELEASE_TARBALL_BASE/$tag.tar.gz"
        if ! command -v curl >/dev/null 2>&1; then
            log_err "curl not found; cannot fetch $url"
            cleanup_staging
            return $EX_NETWORK
        fi
        tarball="$staging/payload.tar.gz"
        if ! curl -fsSL --max-time 60 -o "$tarball" "$url" 2>/dev/null; then
            log_err "failed to fetch $url"
            cleanup_staging
            return $EX_NETWORK
        fi
        observed=$(sha256_file "$tarball")

        # Checksum policy (SPEC-004 §2 FR-015):
        # 1. If EDIKT_INSTALL_SHA256 is set, verify against it.
        # 2. Else fetch the sibling .sha256 reference from GitHub.
        # 3. If the reference is missing, refuse — unless
        #    EDIKT_INSTALL_INSECURE=1 is set explicitly.
        if [ -n "${EDIKT_INSTALL_SHA256:-}" ]; then
            if [ "$observed" != "$EDIKT_INSTALL_SHA256" ]; then
                log_err "checksum mismatch: expected $EDIKT_INSTALL_SHA256, got $observed"
                cleanup_staging
                return $EX_CHECKSUM
            fi
        else
            ref_url="$url.sha256"
            ref_file="$staging/payload.tar.gz.sha256"
            if curl -fsSL --max-time 30 -o "$ref_file" "$ref_url" 2>/dev/null; then
                if ! verify_against_sidecar "$observed" "$ref_file" "$ref_url"; then
                    cleanup_staging
                    return $EX_CHECKSUM
                fi
            elif [ "${EDIKT_INSTALL_INSECURE:-0}" = "1" ]; then
                log_warn "EDIKT_INSTALL_INSECURE=1 — skipping checksum verification (TLS-only trust)"
                log_warn "  tarball sha256: $observed"
            else
                log_err "no checksum reference at $ref_url and EDIKT_INSTALL_SHA256 not set."
                log_err "Either set EDIKT_INSTALL_SHA256=<hex> explicitly, or re-fetch when"
                log_err "the release publishes a .sha256 sidecar. Set EDIKT_INSTALL_INSECURE=1"
                log_err "to override (not recommended)."
                cleanup_staging
                return $EX_CHECKSUM
            fi
        fi
        tarball_sha="$observed"

        # Pre-scan tarball for path-traversal entries. BSD tar on macOS
        # does not strip ../ components, so a malicious archive could
        # write outside extract_dir.
        if ! tarball_safe "$tarball"; then
            log_err "tarball contains unsafe paths (absolute or traversal) — refusing"
            cleanup_staging
            return $EX_MALICIOUS
        fi

        extract_dir="$staging/extracted"
        mkdir "$extract_dir" || { cleanup_staging; return 1; }
        if ! tar -xzf "$tarball" -C "$extract_dir" 2>/dev/null; then
            log_err "tar extraction failed"
            cleanup_staging
            return $EX_NETWORK
        fi
        # GitHub tarballs wrap content in a single top-level dir.
        inner=$(find "$extract_dir" -maxdepth 1 -mindepth 1 -type d | head -1)
        if [ -z "$inner" ]; then
            log_err "tarball appears empty"
            cleanup_staging
            return $EX_NETWORK
        fi
        payload_src="$inner"
        source_type="tarball"
    elif [ -d "$src" ]; then
        # Test/offline path: copy the directory.
        payload_src="$src"
        source_type="dev"
        url=""
    elif [ -f "$src" ]; then
        # Local tarball.
        observed=$(sha256_file "$src")
        if [ -n "${EDIKT_INSTALL_SHA256:-}" ]; then
            if [ "$observed" != "$EDIKT_INSTALL_SHA256" ]; then
                log_err "checksum mismatch: expected $EDIKT_INSTALL_SHA256, got $observed"
                cleanup_staging
                return $EX_CHECKSUM
            fi
        elif [ -f "$src.sha256" ]; then
            # Opportunistic verification: if a sibling .sha256 exists, use it.
            # Local tarballs without a sidecar are implicitly trusted (user
            # chose the file); network tarballs require a sidecar — see the
            # network branch above.
            if ! verify_against_sidecar "$observed" "$src.sha256" "$src.sha256"; then
                cleanup_staging
                return $EX_CHECKSUM
            fi
        fi
        tarball_sha="$observed"
        if ! tarball_safe "$src"; then
            log_err "tarball contains unsafe paths (absolute or traversal) — refusing"
            cleanup_staging
            return $EX_MALICIOUS
        fi
        extract_dir="$staging/extracted"
        mkdir "$extract_dir" || { cleanup_staging; return 1; }
        if ! tar -xzf "$src" -C "$extract_dir" 2>/dev/null; then
            log_err "tar extraction failed"
            cleanup_staging
            return $EX_NETWORK
        fi
        # If extraction produced a top-level VERSION (archive rooted at
        # payload), use extract_dir directly. Otherwise pick the single
        # inner directory (GitHub-style wrapper).
        if [ -f "$extract_dir/VERSION" ]; then
            payload_src="$extract_dir"
        else
            inner=$(find "$extract_dir" -maxdepth 1 -mindepth 1 -type d | head -1)
            payload_src="${inner:-$extract_dir}"
        fi
        source_type="tarball"
        url="file://$src"
    else
        log_err "EDIKT_INSTALL_SOURCE='$src' is not a file or directory"
        cleanup_staging
        return $EX_NETWORK
    fi

    # Stage the payload at staging/<norm>, then atomic mv into versions/.
    final_stage="$staging/$norm"
    if [ "$source_type" = "dev" ]; then
        # cp is unavoidable for a source dir; use a fresh staging dir so
        # if interrupted we leave nothing behind in versions/.
        mkdir -p "$final_stage"
        # Copy contents of source dir.
        ( cd "$payload_src" && tar -cf - . ) | ( cd "$final_stage" && tar -xf - )
    else
        mv "$payload_src" "$final_stage"
    fi

    # Validate VERSION exists and meets MIN_PAYLOAD_VERSION.
    if [ ! -f "$final_stage/VERSION" ]; then
        log_err "payload missing VERSION file"
        cleanup_staging
        return $EX_NETWORK
    fi
    if ! check_payload_min_version "$final_stage"; then
        cleanup_staging
        return $EX_CHECKSUM
    fi

    # Write manifest into the staged tree.
    write_manifest "$final_stage" "$norm" "$source_type" "$url" "$tarball_sha"

    # Atomic move into place.
    mv "$final_stage" "$target"

    rm -rf "$staging" 2>/dev/null || true

    emit_event version_installed \
        '"version":"'"$norm"'","source":"'"$source_type"'","sha256":"'"$tarball_sha"'","installed_via":"launcher"'

    log_info "installed $norm at $target"
    return 0
}

# ─── Subcommand: use ────────────────────────────────────────────────────────
cmd_use() {
    tag="${1:-}"
    if [ -z "$tag" ]; then
        log_err "usage: edikt use <tag>"
        return 1
    fi
    norm=$(normalize_tag "$tag")
    target_dir="$EDIKT_ROOT/versions/$norm"
    if [ ! -d "$target_dir" ]; then
        log_err "version $norm is not installed. Run \`edikt install $tag\` first."
        return 1
    fi

    acquire_lock || return $?

    if ! check_payload_min_version "$target_dir"; then
        return $EX_CHECKSUM
    fi

    prev=""
    if [ -L "$EDIKT_ROOT/current" ]; then
        prev=$(basename "$(readlink "$EDIKT_ROOT/current")")
    fi

    backup_ts=$(flip_current "versions/$norm")

    lock_write "$norm" "launcher"

    extra='"version":"'"$norm"'","symlink":"'"$EDIKT_ROOT"/current'"'
    if [ -n "$prev" ]; then
        extra="$extra"',"previous":"'"$prev"'"'
    fi
    extra="$extra"',"backup":"'"$EDIKT_ROOT"/backups/"$backup_ts"'"'
    emit_event version_activated "$extra"

    log_info "activated $norm"
    return 0
}

# ─── Subcommand: rollback ───────────────────────────────────────────────────
cmd_rollback() {
    prev=$(lock_get previous)
    if [ -z "$prev" ]; then
        log_err "no previous version recorded in lock.yaml"
        return 1
    fi
    if [ ! -d "$EDIKT_ROOT/versions/$prev" ]; then
        log_err "previous version $prev is not installed"
        return 1
    fi
    cur=$(lock_get active)

    acquire_lock || return $?

    backup_ts=$(flip_current "versions/$prev")
    lock_write "$prev" "launcher"

    emit_event rollback_performed \
        '"from":"'"$cur"'","to":"'"$prev"'","backup":"'"$EDIKT_ROOT"/backups/"$backup_ts"'","reason":"user"'

    log_info "rolled back to $prev"
    return 0
}

# ─── Subcommand: doctor ─────────────────────────────────────────────────────
# Exit 0 healthy, 1 warnings, 2 errors.
cmd_doctor() {
    quick=0
    if [ "${1:-}" = "--quick" ]; then quick=1; fi
    warn_n=0
    err_n=0
    echo "edikt doctor"
    if [ "$quick" -eq 1 ]; then
        echo "  mode:             --quick (skip per-file SHA256)"
    fi
    echo "  launcher version: $LAUNCHER_VERSION"
    echo "  EDIKT_ROOT:       $EDIKT_ROOT"
    echo "  CLAUDE_ROOT:      $CLAUDE_ROOT"

    if [ ! -d "$EDIKT_ROOT" ]; then
        echo "  ERROR: EDIKT_ROOT does not exist"
        return 2
    fi
    if [ ! -w "$EDIKT_ROOT" ]; then
        echo "  ERROR: EDIKT_ROOT is not writable"
        err_n=$((err_n + 1))
    fi

    # Active version
    if [ -L "$EDIKT_ROOT/current" ]; then
        active=$(basename "$(readlink "$EDIKT_ROOT/current")")
        echo "  active version:   $active"
        if [ ! -d "$EDIKT_ROOT/current/" ]; then
            echo "  ERROR: current symlink does not resolve"
            err_n=$((err_n + 1))
        fi
    else
        echo "  WARN: no active version (current symlink missing)"
        warn_n=$((warn_n + 1))
    fi

    # Required external symlinks
    for link in hooks templates; do
        if [ ! -L "$EDIKT_ROOT/$link" ]; then
            echo "  WARN: $EDIKT_ROOT/$link is not a symlink"
            warn_n=$((warn_n + 1))
        elif [ ! -e "$EDIKT_ROOT/$link/" ]; then
            echo "  ERROR: $EDIKT_ROOT/$link does not resolve"
            err_n=$((err_n + 1))
        fi
    done
    if [ -L "$CLAUDE_ROOT/commands/edikt" ]; then
        if [ ! -e "$CLAUDE_ROOT/commands/edikt/" ]; then
            echo "  ERROR: $CLAUDE_ROOT/commands/edikt does not resolve"
            err_n=$((err_n + 1))
        fi
    else
        echo "  WARN: $CLAUDE_ROOT/commands/edikt is not a symlink"
        warn_n=$((warn_n + 1))
    fi

    # Manifest integrity for active version
    if [ -L "$EDIKT_ROOT/current" ] && [ -d "$EDIKT_ROOT/current/" ]; then
        if [ -f "$EDIKT_ROOT/current/manifest.yaml" ]; then
            if [ "$quick" -eq 1 ]; then
                echo "  manifest:         present (skipped hash verify)"
            elif ! manifest_verify "$EDIKT_ROOT/current/" 2>/dev/null; then
                echo "  ERROR: manifest integrity check failed"
                err_n=$((err_n + 1))
            else
                echo "  manifest:         OK"
            fi
        else
            echo "  WARN: no manifest.yaml in active version"
            warn_n=$((warn_n + 1))
        fi
    fi

    # MIN_PAYLOAD_VERSION
    if [ -f "$EDIKT_ROOT/current/VERSION" ]; then
        pv=$(head -1 "$EDIKT_ROOT/current/VERSION")
        if version_ge "$pv" "$MIN_PAYLOAD_VERSION"; then
            echo "  payload version:  $pv (>= MIN $MIN_PAYLOAD_VERSION)"
        else
            echo "  ERROR: payload $pv is older than MIN_PAYLOAD_VERSION ($MIN_PAYLOAD_VERSION)"
            err_n=$((err_n + 1))
        fi
    fi

    # Partial/interrupted migration detection (per config-spec §8.2).
    if migration_in_progress; then
        echo "  ERROR: interrupted migration detected — run: edikt migrate --abort"
        err_n=$((err_n + 1))
    fi

    # Pre-v0.5.0 flat layout awaiting migration.
    if needs_migration; then
        echo "  ERROR: flat layout detected — run: edikt migrate [--dry-run]"
        err_n=$((err_n + 1))
    fi

    # Stale .lock detection
    if [ -f "$EDIKT_ROOT/.lock" ]; then
        owner_pid=$(awk '{print $1; exit}' "$EDIKT_ROOT/.lock" 2>/dev/null)
        if [ -n "$owner_pid" ] && ! kill -0 "$owner_pid" 2>/dev/null; then
            echo "  WARN: stale lock from pid $owner_pid (process gone)"
            warn_n=$((warn_n + 1))
        fi
    fi

    if [ "$err_n" -gt 0 ]; then
        echo "result: $err_n errors, $warn_n warnings"
        return 2
    elif [ "$warn_n" -gt 0 ]; then
        echo "result: $warn_n warnings"
        return 1
    else
        echo "result: healthy"
        return 0
    fi
}

# ─── Legacy-layout detection (per SPEC-004 §2 FR-018) ──────────────────────
# Returns 0 if the flat (pre-v0.5.0) layout is present: $EDIKT_ROOT/hooks/ is
# a real directory (not a symlink) AND $EDIKT_ROOT/VERSION exists. Returns 1
# otherwise. Used by the dispatch gate and by `migrate`.
needs_migration() {
    [ -d "$EDIKT_ROOT/hooks" ] && [ ! -L "$EDIKT_ROOT/hooks" ] && [ -f "$EDIKT_ROOT/VERSION" ]
}

# Detects a partial/interrupted migration: presence of any staging or
# pre-migration sibling dir. Used by doctor.
migration_in_progress() {
    for d in "$EDIKT_ROOT"/.migrate-staging-* "$EDIKT_ROOT"/.pre-migration-*; do
        [ -e "$d" ] && return 0
    done
    return 1
}

# ─── Subcommand: migrate ────────────────────────────────────────────────────
# Migrate a pre-v0.5.0 flat layout into the versioned layout.
#   edikt migrate [--dry-run] [--yes] [--abort]
# See SPEC-004 §2 FR-018, §10.M1, and config-spec §8.2.
#
# Atomicity approach:
#   1. Stage the new layout at $EDIKT_ROOT/.migrate-staging-<ts>/<VERSION>/.
#   2. Write pre-migration.tar.gz backup to backups/migration-<ts>/.
#   3. Move flat dirs sideways into $EDIKT_ROOT/.pre-migration-<ts>/.
#   4. Move staged version into versions/<VERSION>/.
#   5. Wire symlink chain (atomic_symlink).
#   6. Write lock.yaml, emit event, remove .pre-migration-<ts>/ last.
# A trap on INT/TERM/EXIT invokes migrate_abort if MIGRATE_STATE != "done".

# Per-migration state. Set in cmd_migrate / migrate_abort.
# States: idle → starting → swapping → done (normal), or aborting (abort path).
MIGRATE_STATE="idle"
MIGRATE_TS=""
MIGRATE_STAGING=""
MIGRATE_PREDIR=""
MIGRATE_BACKUP_DIR=""
MIGRATE_VERSION=""

# Find any existing (orphaned) staging/pre-migration dirs. Echoes one path
# per line. Used by --abort to recover from a crashed prior run.
find_migration_leftovers() {
    for d in "$EDIKT_ROOT"/.migrate-staging-* "$EDIKT_ROOT"/.pre-migration-*; do
        [ -e "$d" ] || continue
        echo "$d"
    done
}

# ─── Safe-removal helpers (review findings #2, #13) ─────────────────────────
# Returns 0 if $1 is an empty directory, 1 otherwise.
_dir_is_empty() {
    _d="$1"
    [ -d "$_d" ] || return 1
    # `find ... -mindepth 1 -print -quit` is non-portable; use shell globbing.
    for _e in "$_d"/* "$_d"/.[!.]* "$_d"/..?*; do
        [ -e "$_e" ] || [ -L "$_e" ] || continue
        return 1
    done
    return 0
}

# Defense-in-depth rm for paths that might contain user content during
# migration recovery. If $1 is a symlink, unlink. If empty dir or regular
# file, rm. If a non-empty directory, REFUSE to rm-rf and instead rename
# to "$1.aborted-<ts>" for human review. Always logs loudly.
# Returns 0 even on rename (caller can check the path is gone); 1 only if
# we fail to move the content out of the way.
_safe_remove_or_quarantine() {
    _tgt="$1"
    _reason="${2:-migrate-abort}"
    if [ ! -e "$_tgt" ] && [ ! -L "$_tgt" ]; then
        return 0
    fi
    if [ -L "$_tgt" ]; then
        rm -f "$_tgt" 2>/dev/null || return 1
        return 0
    fi
    if [ -f "$_tgt" ]; then
        rm -f "$_tgt" 2>/dev/null || return 1
        return 0
    fi
    if [ -d "$_tgt" ] && _dir_is_empty "$_tgt"; then
        rmdir "$_tgt" 2>/dev/null || rm -rf "$_tgt" 2>/dev/null || return 1
        return 0
    fi
    # Non-empty directory: do NOT rm -rf. Quarantine.
    _quar="$_tgt.aborted-$(ts_now)-$$"
    if mv "$_tgt" "$_quar" 2>/dev/null; then
        log_warn "$_reason: refusing to rm-rf non-empty $_tgt — renamed to $_quar for human review"
        return 0
    fi
    log_err "$_reason: could not quarantine $_tgt (mv failed); leaving in place"
    return 1
}

# Verify a migration backup tarball is present and readable. Checks the
# sha256 sidecar if present. Returns 0 on success, 1 otherwise.
# Arguments: backup_dir
_verify_backup_tarball() {
    _bk="$1"
    _tar="$_bk/pre-migration.tar.gz"
    [ -f "$_tar" ] || return 1
    tar -tzf "$_tar" >/dev/null 2>&1 || return 1
    if [ -f "$_tar.sha256" ]; then
        _obs=$(sha256_file "$_tar" 2>/dev/null) || return 1
        verify_against_sidecar "$_obs" "$_tar.sha256" "$_tar.sha256" >/dev/null 2>&1 \
            || return 1
    fi
    return 0
}

# Echo the path of the most recent readable backup dir under
# $EDIKT_ROOT/backups/migration-*, or nothing if none is usable.
_find_latest_backup_dir() {
    _latest=""
    for _b in "$EDIKT_ROOT"/backups/migration-*; do
        [ -d "$_b" ] || continue
        if _verify_backup_tarball "$_b"; then
            _latest="$_b"  # glob expands in sorted order → latest wins
        fi
    done
    [ -n "$_latest" ] && printf '%s\n' "$_latest"
}

# Restore flat layout from $pre_dir (if present) — moves its children back
# into $EDIKT_ROOT/. Safe to call even if individual children are absent.
# Finding #13: if the destination exists and is a NON-EMPTY directory (not a
# symlink), rename it to "$dst.conflict-<ts>" rather than rm-rf'ing it.
migrate_restore_from_predir() {
    pre="$1"
    [ -d "$pre" ] || return 0
    for entry in hooks templates commands VERSION CHANGELOG.md; do
        src="$pre/$entry"
        dst="$EDIKT_ROOT/$entry"
        if [ -e "$src" ] || [ -L "$src" ]; then
            # Clear dst first. Symlinks/regular files: unlink freely — they
            # are artifacts of the half-wired migration. Non-empty dirs:
            # quarantine rather than destroy (defense in depth).
            if [ -L "$dst" ]; then
                rm -f "$dst" 2>/dev/null || true
            elif [ -d "$dst" ]; then
                if _dir_is_empty "$dst"; then
                    rmdir "$dst" 2>/dev/null || true
                else
                    _conflict="$dst.conflict-$(ts_now)-$$"
                    if mv "$dst" "$_conflict" 2>/dev/null; then
                        log_warn "migrate_restore_from_predir: refusing to rm-rf non-empty $dst — renamed to $_conflict for human review"
                    else
                        log_err "migrate_restore_from_predir: could not quarantine $dst; skipping entry $entry"
                        continue
                    fi
                fi
            elif [ -e "$dst" ]; then
                rm -f "$dst" 2>/dev/null || true
            fi
            mv "$src" "$dst" 2>/dev/null || true
        fi
    done
    rmdir "$pre" 2>/dev/null || true
}

# Abort an in-progress or crashed migration. Idempotent.
# Arguments: none (consults MIGRATE_STATE vars and on-disk leftovers).
# Returns 0 on success; non-zero if the backup tarball is missing/corrupt
# AND user content has already been moved into versions/<v> (we refuse to
# touch it in that case — the user needs to recover manually).
#
# Safety model (review finding #2):
#   - BEFORE any destructive op, verify the most recent backup tarball is
#     present and readable (and sha256-matches its sidecar if present).
#   - NEVER rm-rf a non-empty directory that could contain user content:
#     rename to <path>.aborted-<ts>-<pid> instead (quarantine). See
#     _safe_remove_or_quarantine.
#   - When MIGRATE_STATE=swapping and versions/<v> is populated AND the
#     .pre-migration-<ts>/ predir is present, the canonical restore is
#     (a) quarantine versions/<v>, then (b) move predir contents back.
#     The backup is a belt-and-braces third line of defense — we only
#     require its existence; we do NOT actually extract from it here
#     because the predir already holds the originals by design.
migrate_abort() {
    _any=0

    # Inventory. Do we have a predir? A staging? A populated versions/<v>?
    _have_predir=0
    for pre in "$EDIKT_ROOT"/.pre-migration-*; do
        [ -d "$pre" ] && { _have_predir=1; break; }
    done
    _have_staging=0
    for stg in "$EDIKT_ROOT"/.migrate-staging-*; do
        [ -d "$stg" ] && { _have_staging=1; break; }
    done

    # Will we touch a (potentially populated) versions/<v>?
    _will_touch_versions=0
    if [ -n "${MIGRATE_VERSION:-}" ] \
        && [ -d "$EDIKT_ROOT/versions/$MIGRATE_VERSION" ] \
        && [ "$_have_predir" -eq 1 ]; then
        _will_touch_versions=1
    fi

    # Verify backup BEFORE any destructive op (finding #2, final guard).
    # We only require a readable backup when we're actually about to
    # mutate state. A completely-clean abort (no staging, no predir) is
    # a no-op and needs no backup.
    if [ "$_have_predir" -eq 1 ] || [ "$_will_touch_versions" -eq 1 ]; then
        _bk_dir=$(_find_latest_backup_dir)
        if [ -z "$_bk_dir" ]; then
            log_err "migrate-abort: no readable backup tarball found under $EDIKT_ROOT/backups/migration-*"
            log_err "migrate-abort: refusing to mutate state without a verified backup"
            log_err "migrate-abort: inspect $EDIKT_ROOT/.pre-migration-*/ and $EDIKT_ROOT/versions/ manually"
            return 1
        fi
        log_info "migrate-abort: verified backup at $_bk_dir/pre-migration.tar.gz"
    fi

    # 1. Restore any .pre-migration-<ts>/ dirs (crashed or in-progress).
    for pre in "$EDIKT_ROOT"/.pre-migration-*; do
        [ -d "$pre" ] || continue
        _any=1
        log_info "migrate-abort: restoring flat layout from $(basename "$pre")"
        # Tear down partial symlink chain first. These are always symlinks
        # in a half-wired migration; rm -f on a symlink is safe by design.
        for link in "$EDIKT_ROOT/current" "$EDIKT_ROOT/hooks" "$EDIKT_ROOT/templates"; do
            if [ -L "$link" ]; then
                rm -f "$link" 2>/dev/null || true
            fi
        done
        # Tear down the in-place versions/<v> tree only if it was the target
        # of this migration. Finding #2: the tree may already contain the
        # user's content (copied from staging during step e-ii). NEVER rm-rf
        # blindly. Quarantine first if non-empty, THEN restore from predir.
        if [ -n "${MIGRATE_VERSION:-}" ] && [ -d "$EDIKT_ROOT/versions/$MIGRATE_VERSION" ]; then
            _safe_remove_or_quarantine "$EDIKT_ROOT/versions/$MIGRATE_VERSION" "migrate-abort" \
                || log_err "migrate-abort: versions/$MIGRATE_VERSION could not be moved aside; continuing"
            # Only remove the versions/ dir itself if it is now empty.
            _dir_is_empty "$EDIKT_ROOT/versions" \
                && rmdir "$EDIKT_ROOT/versions" 2>/dev/null || true
        fi
        # Remove lock.yaml written by the aborted migration. Only remove if
        # it names the aborted version — we wrote it fresh during migration.
        if [ -n "${MIGRATE_VERSION:-}" ] && [ -f "$EDIKT_ROOT/lock.yaml" ]; then
            _active=$(lock_get active)
            if [ "$_active" = "$MIGRATE_VERSION" ]; then
                rm -f "$EDIKT_ROOT/lock.yaml" 2>/dev/null || true
            fi
        fi
        migrate_restore_from_predir "$pre"
    done

    # 2. Remove any stale staging dirs. Staging is always our own tree
    # (copied from flat, never the user's live content), so rm -rf is
    # safe here — but only under .migrate-staging-* paths.
    for stg in "$EDIKT_ROOT"/.migrate-staging-*; do
        [ -d "$stg" ] || continue
        _any=1
        log_info "migrate-abort: removing staging $(basename "$stg")"
        rm -rf "$stg" 2>/dev/null || true
    done

    if [ "$_any" -eq 1 ]; then
        emit_event migration_aborted \
            '"reason":"abort","root":"'"$EDIKT_ROOT"'"'
        log_info "migrate-abort: complete"
    fi
    return 0
}

# Trap handler used during migration. Called on EXIT/INT/TERM.
# $1 is the exit status we received (from EXIT trap: use $?).
migrate_trap_handler() {
    _rc="${1:-1}"
    # If we already committed successfully, only release the lock.
    if [ "$MIGRATE_STATE" = "done" ]; then
        release_lock
        return 0
    fi
    # Otherwise treat as interrupted — abort.
    MIGRATE_STATE="aborting"
    migrate_abort 2>/dev/null || true
    release_lock
    # For INT (130) / TERM (143), re-signal ourselves so shell reports it.
    case "$_rc" in
        130|143) exit "$_rc" ;;
        *) ;;
    esac
}

cmd_migrate() {
    dry_run=0
    assume_yes=0
    abort_only=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --dry-run) dry_run=1 ;;
            --yes|-y)  assume_yes=1 ;;
            --abort)   abort_only=1 ;;
            -h|--help)
                cat <<EOF
Usage: edikt migrate [--dry-run] [--yes] [--abort]

Migrate a pre-v0.5.0 flat layout (hooks/ as directory) into the versioned
layout. Dry-run previews the move plan without mutation. --yes bypasses the
interactive confirmation. --abort restores state from any crashed or
in-progress migration.
EOF
                return 0
                ;;
            *) log_err "unknown flag: $1"; return 1 ;;
        esac
        shift
    done

    # --abort bypasses detection; it's a pure recovery command.
    if [ "$abort_only" -eq 1 ]; then
        acquire_lock || return $?
        if ! migration_in_progress; then
            release_lock
            log_info "nothing to abort (no staging or pre-migration directory found)"
            return 0
        fi
        migrate_abort
        _abort_rc=$?
        release_lock
        return "$_abort_rc"
    fi

    # Detect the flat layout.
    if ! needs_migration; then
        # Check for an orphaned partial migration (crash with no flat left).
        if migration_in_progress; then
            log_warn "partial migration detected. Run: edikt migrate --abort"
            return 1
        fi
        log_info "No migration needed."
        return 0
    fi

    MIGRATE_VERSION=$(head -1 "$EDIKT_ROOT/VERSION" | tr -d '[:space:]')
    if [ -z "$MIGRATE_VERSION" ]; then
        log_err "cannot read version from $EDIKT_ROOT/VERSION"
        return 1
    fi
    # Shape gate (review finding #5). VERSION is untrusted user-owned input;
    # it later feeds directory paths ("$EDIKT_ROOT/versions/$MIGRATE_VERSION").
    # Reject anything that isn't a semver-ish plain identifier before we
    # create any directory or backup. No slashes, no `..`, no shell metacharacters.
    case "$MIGRATE_VERSION" in
        *[!0-9A-Za-z._-]* | *..* | /* | */* | .* | -*)
            log_err "refusing to migrate: VERSION ($MIGRATE_VERSION) is not a valid semver-ish identifier"
            return 1
            ;;
    esac
    if ! printf '%s' "$MIGRATE_VERSION" \
        | awk '/^[0-9]+\.[0-9]+\.[0-9]+([.-][A-Za-z0-9]+)*$/ {ok=1} END {exit !ok}'; then
        log_err "refusing to migrate: VERSION ($MIGRATE_VERSION) does not match ^[0-9]+.[0-9]+.[0-9]+([.-][A-Za-z0-9]+)*$"
        return 1
    fi

    # Print the plan. Always show, even in --yes mode.
    echo "Migration needed: flat layout → versioned layout (target: $MIGRATE_VERSION)"
    echo ""
    echo "Will move:"
    for entry in hooks templates commands VERSION CHANGELOG.md; do
        if [ -e "$EDIKT_ROOT/$entry" ] || [ -L "$EDIKT_ROOT/$entry" ]; then
            echo "  $EDIKT_ROOT/$entry  →  $EDIKT_ROOT/versions/$MIGRATE_VERSION/$entry"
        fi
    done
    echo ""
    echo "Will create symlinks:"
    echo "  $EDIKT_ROOT/current      → versions/$MIGRATE_VERSION"
    echo "  $EDIKT_ROOT/hooks        → current/hooks"
    echo "  $EDIKT_ROOT/templates    → current/templates"
    echo "  $CLAUDE_ROOT/commands/edikt → $EDIKT_ROOT/current/commands/edikt"
    echo ""
    echo "Will preserve:"
    for entry in config.yaml custom backups events.jsonl lock.yaml; do
        if [ -e "$EDIKT_ROOT/$entry" ]; then
            echo "  $EDIKT_ROOT/$entry (untouched)"
        fi
    done
    echo ""
    # Review finding #4 — surface the single most important safety property.
    echo "Backup:"
    echo "  $EDIKT_ROOT/backups/migration-<ts>/pre-migration.tar.gz"
    echo "  $EDIKT_ROOT/backups/migration-<ts>/pre-migration.tar.gz.sha256"
    echo "  (use 'edikt migrate --abort' to restore from the most recent backup)"
    echo ""

    if [ "$dry_run" -eq 1 ]; then
        echo "(dry-run: no changes written)"
        return 0
    fi

    # Consent.
    if [ "$assume_yes" -ne 1 ]; then
        # Refuse to prompt only when there is no viable channel at all:
        # stdin is not a tty AND /dev/tty is neither readable nor a
        # character device. Review finding #10: original expression
        # parsed as `(A || B) && C` due to POSIX left-associativity of
        # `||`/`&&`; rewritten with explicit grouping so a readable
        # /dev/tty alone is enough to proceed.
        if { [ ! -r /dev/tty ] || [ ! -t 0 ]; } && [ ! -c /dev/tty ]; then
            log_err "non-interactive session detected. Re-run with --yes to confirm migration."
            return 1
        fi
        printf 'Proceed? [y/N]: ' >/dev/tty 2>/dev/null || printf 'Proceed? [y/N]: ' >&2
        if ! read -r reply </dev/tty 2>/dev/null; then
            log_err "cannot read from /dev/tty. Re-run with --yes."
            return 1
        fi
        case "$reply" in
            y|Y|yes|YES) ;;
            *) log_info "aborted"; return 0 ;;
        esac
    fi

    acquire_lock || return $?

    # State transitions are observed by the global edikt_exit_trap
    # dispatcher (see finding #17). Do NOT swap traps here.
    MIGRATE_STATE="starting"
    MIGRATE_TS=$(ts_now)
    # Review finding #16 — align staging/predir naming with cmd_install's
    # `<prefix>-<ts>-<pid>` pattern so leftovers from one run never collide
    # with another and patterns used by tests/doctor remain stable.
    MIGRATE_STAGING="$EDIKT_ROOT/.migrate-staging-$MIGRATE_TS-$$"
    MIGRATE_PREDIR="$EDIKT_ROOT/.pre-migration-$MIGRATE_TS-$$"
    MIGRATE_BACKUP_DIR="$EDIKT_ROOT/backups/migration-$MIGRATE_TS-$$"

    # Step a: create backup first (before any mutation).
    mkdir -p "$MIGRATE_BACKUP_DIR" || return 1
    # Review finding #11: build the tar file list with positional parameters
    # instead of relying on word-splitting of an unquoted variable. Only
    # include entries that actually exist on disk.
    set --
    for entry in hooks templates commands VERSION CHANGELOG.md; do
        if [ -e "$EDIKT_ROOT/$entry" ] || [ -L "$EDIKT_ROOT/$entry" ]; then
            set -- "$@" "$entry"
        fi
    done
    if [ "$#" -eq 0 ]; then
        log_err "no legacy layout entries found to back up"
        return 1
    fi
    if ! ( cd "$EDIKT_ROOT" && tar -czf "$MIGRATE_BACKUP_DIR/pre-migration.tar.gz" "$@" 2>/dev/null ); then
        log_err "failed to create pre-migration backup tarball"
        return 1
    fi
    if ! tar -tzf "$MIGRATE_BACKUP_DIR/pre-migration.tar.gz" >/dev/null 2>&1; then
        log_err "pre-migration backup tarball is not readable"
        return 1
    fi
    # Review finding #12 — write a sha256 sidecar next to the tarball so
    # migrate_abort (and humans) can confirm the backup is intact before any
    # destructive operation. Mirrors manifest.yaml's sidecar pattern.
    _bk_hash=$(sha256_file "$MIGRATE_BACKUP_DIR/pre-migration.tar.gz") || {
        log_err "failed to compute backup sha256"
        return 1
    }
    printf '%s  pre-migration.tar.gz\n' "$_bk_hash" \
        >"$MIGRATE_BACKUP_DIR/pre-migration.tar.gz.sha256" || {
        log_err "failed to write backup sha256 sidecar"
        return 1
    }
    log_info "migrate: wrote pre-migration backup to $MIGRATE_BACKUP_DIR/pre-migration.tar.gz"
    log_info "migrate: backup sha256 recorded in pre-migration.tar.gz.sha256"

    # Step b+c: create staging dir and copy flat layout into it.
    if ! mkdir "$MIGRATE_STAGING" 2>/dev/null; then
        log_err "staging dir already exists: $MIGRATE_STAGING"
        return 1
    fi
    stage_version_dir="$MIGRATE_STAGING/$MIGRATE_VERSION"
    mkdir "$stage_version_dir" || return 1
    for entry in hooks templates commands VERSION CHANGELOG.md; do
        src="$EDIKT_ROOT/$entry"
        [ -e "$src" ] || [ -L "$src" ] || continue
        # tar-pipe preserves modes, symlinks, and is portable.
        if [ -d "$src" ] && [ ! -L "$src" ]; then
            ( cd "$EDIKT_ROOT" && tar -cf - "$entry" ) | ( cd "$stage_version_dir" && tar -xf - ) \
                || { log_err "failed to copy $entry into staging"; return 1; }
        else
            cp "$src" "$stage_version_dir/$entry" || { log_err "failed to copy $entry"; return 1; }
        fi
    done

    # Step d: write manifest into the staged version dir.
    write_manifest "$stage_version_dir" "$MIGRATE_VERSION" "migration" "" ""

    # Validate manifest is readable and self-consistent.
    if ! manifest_verify "$stage_version_dir" >/dev/null 2>&1; then
        log_err "staged manifest verification failed"
        return 1
    fi

    MIGRATE_STATE="swapping"

    # Step e: atomic-ish swap.
    # (i) move flat entries sideways into .pre-migration-<ts>/
    mkdir "$MIGRATE_PREDIR" || return 1
    for entry in hooks templates commands VERSION CHANGELOG.md; do
        src="$EDIKT_ROOT/$entry"
        if [ -e "$src" ] || [ -L "$src" ]; then
            mv "$src" "$MIGRATE_PREDIR/$entry" || {
                log_err "failed to move $entry sideways — will be restored by abort"
                return 1
            }
        fi
    done

    # (ii) move staged version into versions/<VERSION>/
    mkdir -p "$EDIKT_ROOT/versions"
    if [ -e "$EDIKT_ROOT/versions/$MIGRATE_VERSION" ]; then
        log_err "versions/$MIGRATE_VERSION already exists — refusing to overwrite"
        return 1
    fi
    mv "$stage_version_dir" "$EDIKT_ROOT/versions/$MIGRATE_VERSION" \
        || { log_err "failed to move staged version into place"; return 1; }

    # (iii) wire the symlink chain atomically.
    atomic_symlink "versions/$MIGRATE_VERSION" "$EDIKT_ROOT/current" \
        || { log_err "failed to create current symlink"; return 1; }
    ensure_external_symlinks

    # Step f: write lock.yaml (active=<VERSION>, previous=null implicit).
    lock_write "$MIGRATE_VERSION" "migration"

    # Step g: emit success event.
    emit_event layout_migrated \
        '"from":"flat","to":"versioned","version":"'"$MIGRATE_VERSION"'","backup":"'"$MIGRATE_BACKUP_DIR"'"'

    # Step h: commit — remove the .pre-migration-<ts>/ holding dir.
    # Setting MIGRATE_STATE=done BEFORE any rm ensures the global exit
    # trap (edikt_exit_trap) treats us as committed even if a signal
    # lands between here and function return (see finding #17).
    MIGRATE_STATE="done"
    rm -rf "$MIGRATE_PREDIR" 2>/dev/null || true
    rm -rf "$MIGRATE_STAGING" 2>/dev/null || true

    log_info "migration complete: $MIGRATE_VERSION activated"
    return 0
}

# ─── Subcommand: uninstall ──────────────────────────────────────────────────
cmd_uninstall() {
    yes=0
    if [ "${1:-}" = "--yes" ] || [ "${1:-}" = "-y" ]; then yes=1; fi

    if [ "$yes" -ne 1 ]; then
        printf 'Remove %s and unlink %s/commands/edikt? [y/N]: ' "$EDIKT_ROOT" "$CLAUDE_ROOT" >&2
        # /dev/tty fallback so non-interactive callers without --yes abort.
        if [ -t 0 ]; then
            read -r reply
        else
            reply=""
        fi
        case "$reply" in
            y|Y|yes|YES) ;;
            *) log_info "aborted"; return 0 ;;
        esac
    fi

    # Safety guards before rm -rf:
    # (a) refuse if $EDIKT_ROOT itself is a symlink — rm -rf would follow
    #     the link and nuke the target directory's contents.
    if [ -L "$EDIKT_ROOT" ]; then
        log_err "refusing to uninstall: $EDIKT_ROOT is a symlink."
        log_err "Remove it manually after verifying the target."
        return $EX_ALREADY
    fi
    # (b) require identifying markers so we don't nuke an unrelated
    #     directory pointed at via EDIKT_ROOT.
    base=$(basename "$EDIKT_ROOT")
    if [ "$base" != ".edikt" ] \
        && [ ! -f "$EDIKT_ROOT/lock.yaml" ] \
        && [ ! -f "$EDIKT_ROOT/VERSION" ] \
        && [ ! -d "$EDIKT_ROOT/versions" ]; then
        log_err "refusing to uninstall: $EDIKT_ROOT does not look like an edikt root"
        log_err "(basename is not '.edikt' and no lock.yaml/VERSION/versions/ found)."
        return $EX_ALREADY
    fi

    acquire_lock || return $?

    # Unlink Claude command symlink.
    if [ -L "$CLAUDE_ROOT/commands/edikt" ]; then
        rm -f "$CLAUDE_ROOT/commands/edikt"
    fi

    # Release lock first since we're about to nuke the lock dir.
    release_lock

    rm -rf "$EDIKT_ROOT"
    log_info "uninstalled"
    return 0
}

# ─── Help ───────────────────────────────────────────────────────────────────
cmd_help() {
    cat <<EOF
edikt — governance for agentic engineering (launcher v$LAUNCHER_VERSION)

Usage: edikt <subcommand> [args]

Subcommands:
  version              Print active payload version
  list [--verbose]     List installed versions
  install <tag>        Fetch + extract release; does not activate
  use <tag>            Activate an installed version (atomic symlink flip)
  rollback             Re-activate the previous version
  migrate [flags]      Migrate pre-v0.5.0 flat layout → versioned layout
                       Flags: --dry-run, --yes, --abort
  doctor [--quick]     Verify symlink chain + manifest integrity
                       (--quick skips per-file SHA256 verification)
  uninstall [--yes]    Remove EDIKT_ROOT + commands symlink

Environment:
  EDIKT_ROOT           Root of edikt state. Defaults: project mode (walks
                       up for .edikt/bin/edikt) → \$EDIKT_HOME → \$HOME/.edikt.
  CLAUDE_HOME          Override \$HOME/.claude.
  EDIKT_INSTALL_SOURCE Local tarball or directory used by \`install\` instead
                       of GitHub (test + offline path).
  EDIKT_INSTALL_SHA256 Expected sha256 of the tarball; mismatch exits 2.
  EDIKT_INSTALL_INSECURE
                       Set to 1 to skip checksum verification when neither
                       EDIKT_INSTALL_SHA256 nor a fetched .sha256 sidecar
                       is available. Not recommended.

Layout (per SPEC-004 §1):
  \$EDIKT_ROOT/
    bin/edikt                    launcher (this script)
    versions/<tag>/              immutable payloads
    current -> versions/<tag>    generation symlink
    hooks -> current/hooks       stable external path
    templates -> current/templates
    config.yaml, custom/         user data — never touched
    backups/<ts>/                pre-flip snapshots
    lock.yaml                    active + previous + history
    events.jsonl                 install/activate/rollback events
EOF
}

# ─── Dispatch ───────────────────────────────────────────────────────────────
sub="${1:-help}"
shift 2>/dev/null || true

# Interrupted-migration gate (review finding #1). On-disk markers
# (.migrate-staging-*/, .pre-migration-*/) evidence an in-flight or
# crashed migration from another process. Running ANY state-changing
# subcommand now would race against recovery. Admit only migrate (which
# holds the lock) and diagnostic/help commands. This check happens
# BEFORE needs_migration so that a partial-crash state (flat layout
# already torn down but predir still present) is still caught.
# NB: we deliberately do NOT acquire the lock here — doctor must remain
# reachable precisely when a stuck holder has the lock.
if migration_in_progress; then
    case "$sub" in
        migrate|doctor|version|--version|-v|help|--help|-h|"") ;;
        *)
            log_err "Migration in progress — wait for it to complete or run: edikt migrate --abort"
            exit 1
            ;;
    esac
fi

# Legacy-layout gate (per SPEC-004 §2 FR-018). If pre-v0.5.0 flat layout is
# detected, only migrate/doctor/version/help are reachable. Every other
# subcommand refuses with a migration-needed message and exit 1.
if needs_migration; then
    case "$sub" in
        migrate|doctor|version|--version|-v|help|--help|-h|"") ;;
        *)
            log_err "Layout migration needed. Run: edikt migrate [--dry-run]"
            exit 1
            ;;
    esac
fi

case "$sub" in
    version|--version|-v) cmd_version "$@" ;;
    list|ls)              cmd_list "$@" ;;
    install)              cmd_install "$@" ;;
    use)                  cmd_use "$@" ;;
    rollback)             cmd_rollback "$@" ;;
    migrate)              cmd_migrate "$@" ;;
    doctor)               cmd_doctor "$@" ;;
    uninstall)            cmd_uninstall "$@" ;;
    help|--help|-h|"")    cmd_help ;;
    *)
        log_err "unknown subcommand: $sub"
        cmd_help >&2
        exit 1
        ;;
esac
