# edikt-managed gitignore — runtime state and caches generated by edikt
# commands. These files differ per-user/per-machine and should never be
# committed. Git honors nested .gitignore files, so this covers every
# edikt project without touching the root .gitignore.

# Runtime state: compile history, orphan-ADR caches, evaluator verdicts,
# anything written by edikt commands during normal use.
state/
