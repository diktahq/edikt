{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/verikt-check.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/verikt-guide-refresh.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "startup"
      }
    ]
  }
}
