---
paths:
{{- range .Paths }}
  - "{{ . }}"
{{- end }}
compile_schema_version: 2
{{- if .Fingerprint }}
_fingerprint: "{{ .Fingerprint }}"
{{- end }}
---
<!-- edikt:compiled — generated by gov-compile, do not edit manually -->
<!-- topic: {{ .Name }} -->
<!-- sources: {{ joinSources .Sources }} -->
<!-- compiled_by: gov-compile v{{ .CompilerVersion }} -->
<!-- compiled_at: {{ .CompiledAt }} -->

# {{ title .Name }}

[edikt:directives:start]: #
{{ range .DirectiveLines }}- {{ . }}
{{ end -}}
[edikt:directives:end]: #
[edikt:directives:sha256]: # {{ .DirectivesSHA }}

[edikt:prohibitions:start]: #
## Prohibitions
{{ range .ProhibitionLines }}- {{ . }}
{{ end -}}
[edikt:prohibitions:end]: #
[edikt:prohibitions:sha256]: # {{ .ProhibitionsSHA }}

[edikt:manual:start]: #
{{ range .ManualLines }}- {{ . }}
{{ end -}}
[edikt:manual:end]: #
[edikt:manual:sha256]: # {{ .ManualSHA }}
